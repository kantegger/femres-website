---
import Layout from "../../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { createT } from "../../../i18n/index";
import { type Locale } from "../../../i18n/types";
import {
  findTopicByName,
  getTopicIcon,
  getTopicTranslation,
} from "../../../i18n/topicsUtils";

export async function getStaticPaths() {
  const locales = ["en", "zh-CN", "zh-TW", "ja", "fr"];
  return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const currentLocale = locale as Locale;
const t = createT(currentLocale);

// 获取所有内容以统计主题
const books = await getCollection("books");
const articles = await getCollection("articles");
const videos = await getCollection("videos");
const podcasts = await getCollection("podcasts");
const papers = await getCollection("papers");
const films = await getCollection("films");

const allContent = [
  ...books.map((item) => ({ ...item, contentType: "book" as const })),
  ...articles.map((item) => ({ ...item, contentType: "article" as const })),
  ...videos.map((item) => ({ ...item, contentType: "video" as const })),
  ...podcasts.map((item) => ({ ...item, contentType: "podcast" as const })),
  ...papers.map((item) => ({ ...item, contentType: "paper" as const })),
  ...films.map((item) => ({ ...item, contentType: "film" as const })),
];

// Determine suffix for filtering content by locale
// This matches the logic used in [...slug].astro files
const suffix =
  currentLocale === "zh-CN"
    ? ""
    : currentLocale === "zh-TW"
      ? "-tw"
      : `-${currentLocale}`;

// Filter content for the current locale
const localeContent = allContent.filter((item) => {
  // Check if item matches the current locale's suffix
  if (currentLocale === "zh-CN") {
    // For zh-CN (empty suffix), exclude items with other known suffixes
    // Note: This logic assumes zh-CN files have no suffix
    // Modify based on your project's exact file naming convention
    const hasOtherSuffix = ["-en", "-ja", "-fr", "-cht"].some((s) =>
      item.slug.endsWith(s),
    );
    return !hasOtherSuffix;
  } else {
    return item.slug.endsWith(suffix);
  }
});

// Calculate topic counts based on content available in current locale
const topicCounts = localeContent.reduce(
  (acc, item) => {
    // item.data.topics usually contains English/Canonical keys
    if (item.data.topics && Array.isArray(item.data.topics)) {
      item.data.topics.forEach((topic: string) => {
        acc[topic] = (acc[topic] || 0) + 1;
      });
    }
    return acc;
  },
  {} as Record<string, number>,
);

// 主题分类定义 (Original structure with Chinese keys, mapped to English keys dynamically)
const topicCategories = {
  理论流派: {
    topics: [
      "交叉女性主义",
      "马克思主义女性主义",
      "去殖民女性主义",
      "存在主义女性主义",
      "自由主义女性主义",
      "激进女性主义",
      "黑人女性主义",
      "原住民女性主义",
      "跨性别女性主义",
      "生态女性主义",
      "后现代女性主义",
      "无政府女性主义",
      "东亚女性主义",
    ],
    icon: "🧩",
    // Key for translation
    mappingKey: "theoreticalschools",
  },
  运动议题: {
    topics: [
      "职场平等",
      "同工同酬",
      "玻璃天花板",
      "生育自主",
      "堕胎权",
      "反性暴力",
      "政治参与",
      "法律平等",
      "经济赋权",
      "教育平等",
      "家庭解放",
      "体育平等",
      "身体自主",
      "数字女性主义",
      "气候正义",
      "社区行动主义",
      "老年女性权利",
      "劳动权利",
      "贫困与正义",
      "社会正义",
      "女性健康",
      "反种族主义政治",
    ],
    icon: "✊",
    mappingKey: "movementissues",
  },
  批判领域: {
    topics: [
      "父权制批判",
      "资本主义批判",
      "媒体表征批判",
      "宗教父权批判",
      "男权运动批判",
      "文化批判",
      "反女性主义研究",
      "学术父权批判",
      "语言性别歧视",
      "翻译政治",
      "知识殖民批判",
      "算法偏见",
      "审美标准批判",
      "生命伦理学",
      "消费主义批判",
      "医疗父权批判",
      "政治批判",
      "性政治",
      "年龄歧视与性别",
    ],
    icon: "🔍",
    mappingKey: "criticaldomains", // Note: 'criticaldomains' in en.json (singular/plural check needed?)
  },
  历史脉络: {
    topics: [
      "第一波女性主义",
      "第二波女性主义",
      "第三波女性主义",
      "第四波女性主义",
      "MeToo运动",
      "中国女权运动",
      "流行文化女性主义",
      "基督教女性主义",
      "灵性女性主义",
      "女性历史",
    ],
    icon: "📚",
    mappingKey: "historicalcontext",
  },
  文学与创作: {
    topics: [
      "女性文学",
      "女性写作",
      "女性文学批评",
      "翻译女性主义",
      "女性叙事学",
      "先锋电影",
    ],
    icon: "✍️",
    mappingKey: "literature&creation",
  },
  特殊概念: {
    topics: [
      "情绪劳动",
      "关怀伦理",
      "女性主义心理学",
      "女性主义艺术",
      "种族与性别",
      "母女关系",
      "女性友谊",
      "酷儿身份",
      "移民身份认同",
      "文化认同",
      "青少年发展",
      "阶级与性别",
      "国际语境",
      "激进幽默",
      "发声与沉默",
    ],
    icon: "💡",
    mappingKey: "specialconcepts",
  },
};

// 为每个分类添加统计数据和翻译信息
const enrichedCategories = Object.entries(topicCategories).map(
  ([categoryName, category]) => {
    // Use mappingKey to get localized title and description
    const categoryTitle = t(`topicsPage.categories.${category.mappingKey}`);
    const categoryDesc = t(
      `topicsPage.categoryDescriptions.${category.mappingKey}`,
    );

    // Process topics
    const processedTopics = category.topics.map((topicZhName) => {
      // 1. Find canonical English key from the hardcoded Chinese name
      const topicInfo = findTopicByName(topicZhName);
      const englishName = topicInfo?.enName || topicZhName; // Fallback to current name if not found

      // 2. Get translation for display in current locale
      // Note: passed topic should be english key if we want getTopicTranslation to map it correctly from mapping file
      const displayName = getTopicTranslation(englishName, currentLocale);

      // 3. Get count
      const count = topicCounts[englishName] || 0;

      return {
        englishName,
        displayName,
        count,
        icon: topicInfo?.icon || "📋",
      };
    });

    return {
      name: categoryTitle,
      description: categoryDesc,
      icon: category.icon,
      totalContent: processedTopics.reduce(
        (sum, topic) => sum + topic.count,
        0,
      ),
      topics: processedTopics,
    };
  },
);

// 获取热门主题（按内容数量排序）
// Need to iterate ALL known topics from topicCounts to find popular ones,
// not just the ones in categories (though most should be in categories)
// But wait, topicCounts keys are English keys.
const popularTopics = Object.entries(topicCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12)
  .map(([englishName, count]) => {
    const displayName = getTopicTranslation(englishName, currentLocale);
    const icon = getTopicIcon(englishName);
    return {
      englishName,
      displayName,
      count,
      icon,
    };
  });
---

<Layout
  title={`${t("topicsPage.title")} - FemRes`}
  description={t("topicsPage.subtitle")}
>
  <!-- Hero Section -->
  <section class="relative py-12 sm:py-16 lg:py-20 overflow-hidden">
    <!-- Background decorative elements -->
    <div class="absolute inset-0 -z-10">
      <div
        class="absolute top-20 left-20 w-32 sm:w-48 lg:w-72 h-32 sm:h-48 lg:h-72 bg-purple-300 rounded-full mix-blend-multiply filter blur-xl opacity-20 animate-blob"
      >
      </div>
      <div
        class="absolute top-10 right-10 w-32 sm:w-48 lg:w-72 h-32 sm:h-48 lg:h-72 bg-pink-300 rounded-full mix-blend-multiply filter blur-xl opacity-20 animate-blob animation-delay-2000"
      >
      </div>
      <div
        class="absolute bottom-20 left-1/3 w-32 sm:w-48 lg:w-72 h-32 sm:h-48 lg:h-72 bg-indigo-300 rounded-full mix-blend-multiply filter blur-xl opacity-20 animate-blob animation-delay-4000"
      >
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1
          class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 dark:text-white mb-4 sm:mb-6"
        >
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-pink-600"
          >
            {t("topicsPage.title")}
          </span>
        </h1>
        <p
          class="text-lg sm:text-xl md:text-2xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto px-4"
        >
          {t("topicsPage.subtitle")}
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <!-- Popular Topics -->
    <section class="mb-16 sm:mb-20">
      <div class="text-center mb-12">
        <h2
          class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4"
        >
          {t("topicsPage.popularTopics")}
        </h2>
        <p
          class="text-lg sm:text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto"
        >
          {t("topicsPage.popularTopicsDesc")}
        </p>
      </div>

      <div
        class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6"
      >
        {
          popularTopics.map((topic) => (
            <a
              href={`/${currentLocale}/topics/${topic.englishName}`}
              class="group bg-white dark:bg-gray-800 rounded-2xl p-6 border border-gray-200 dark:border-gray-700 hover:shadow-xl hover:border-purple-300 dark:hover:border-purple-600 transition-all duration-300 hover:-translate-y-1"
            >
              <div class="text-center">
                <div class="text-4xl mb-3">{topic.icon}</div>
                <h3 class="font-semibold text-gray-900 dark:text-white mb-2 group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors">
                  {topic.displayName}
                </h3>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 dark:bg-purple-900 text-purple-800 dark:text-purple-200">
                  {t("common.itemsCount", { count: topic.count })}
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Topic Categories -->
    {
      enrichedCategories.map((category) => (
        <section class="mb-16 sm:mb-20">
          <div class="flex items-center mb-8">
            <div class="flex items-center">
              <span class="text-3xl mr-4">{category.icon}</span>
              <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">
                {category.name}
              </h2>
              <span class="ml-4 px-3 py-1 text-sm bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400 rounded-full">
                {t("topicsPage.topicsCount", {
                  count: category.topics.filter((topic) => topic.count > 0)
                    .length,
                })}
              </span>
            </div>
          </div>

          <div class="mb-4 p-4 bg-gradient-to-r from-purple-50 to-pink-50 dark:from-purple-900/20 dark:to-pink-900/20 rounded-xl">
            <p class="text-gray-700 dark:text-gray-300 mb-2">
              {category.description}
            </p>
            <div class="flex items-center text-sm text-purple-600 dark:text-purple-400">
              <span class="font-semibold">
                {t("topicsPage.totalContent", { count: category.totalContent })}
              </span>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 sm:gap-6">
            {category.topics.map((topic) => (
              <div class="group">
                {topic.count > 0 ? (
                  <a
                    href={`/${currentLocale}/topics/${topic.englishName}`}
                    class="block bg-white dark:bg-gray-800 rounded-xl p-5 border border-gray-200 dark:border-gray-700 hover:shadow-lg hover:border-purple-300 dark:hover:border-purple-600 transition-all duration-200 hover:-translate-y-0.5"
                  >
                    <div class="flex items-center">
                      <span class="text-2xl mr-3">{topic.icon}</span>
                      <div class="flex-1 min-w-0">
                        <h3 class="font-medium text-gray-900 dark:text-white group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors truncate">
                          {topic.displayName}
                        </h3>
                        <span class="text-sm text-gray-500 dark:text-gray-400">
                          {t("common.itemsCount", { count: topic.count })}
                        </span>
                      </div>
                    </div>
                  </a>
                ) : (
                  <div class="bg-gray-50 dark:bg-gray-900 rounded-xl p-5 border border-gray-200 dark:border-gray-700 opacity-60">
                    <div class="flex items-center">
                      <span class="text-2xl mr-3 grayscale">{topic.icon}</span>
                      <div class="flex-1 min-w-0">
                        <h3 class="font-medium text-gray-500 dark:text-gray-400 truncate">
                          {topic.displayName}
                        </h3>
                        <span class="text-sm text-gray-400 dark:text-gray-500">
                          {t("topicsPage.comingSoon")}
                        </span>
                      </div>
                    </div>
                  </div>
                )}
              </div>
            ))}
          </div>
        </section>
      ))
    }

    <!-- Call to Action -->
    <section class="text-center">
      <div
        class="bg-gradient-to-br from-purple-50 to-pink-50 dark:from-gray-800 dark:to-gray-900 rounded-3xl p-8 sm:p-12"
      >
        <h2
          class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4"
        >
          {t("topicsPage.contributeTitle")}
        </h2>
        <p
          class="text-lg sm:text-xl text-gray-600 dark:text-gray-300 mb-8 max-w-2xl mx-auto"
        >
          {t("topicsPage.contributeDesc")}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href={`/${currentLocale}/contribute`}
            class="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-200"
          >
            {t("topicsPage.submitContent")}
            <svg
              class="ml-2 w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 4v16m8-8H4"></path>
            </svg>
          </a>
          <a
            href={`/${currentLocale}/search`}
            class="inline-flex items-center justify-center px-8 py-4 border border-purple-600 text-purple-600 dark:text-purple-400 hover:bg-purple-50 dark:hover:bg-purple-900/20 font-semibold rounded-xl transition-all duration-200"
          >
            {t("topicsPage.searchContent")}
            <svg
              class="ml-2 w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </a>
        </div>
      </div>
    </section>
  </div>

  <style>
    @keyframes blob {
      0% {
        transform: translate(0px, 0px) scale(1);
      }
      33% {
        transform: translate(30px, -50px) scale(1.1);
      }
      66% {
        transform: translate(-20px, 20px) scale(0.9);
      }
      100% {
        transform: translate(0px, 0px) scale(1);
      }
    }
    .animate-blob {
      animation: blob 7s infinite;
    }
    .animation-delay-2000 {
      animation-delay: 2s;
    }
    .animation-delay-4000 {
      animation-delay: 4s;
    }
  </style>
</Layout>
