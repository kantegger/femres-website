---
export const prerender = true;

import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import InteractionButtons from "../../../components/InteractionButtons";
import Discussion from "../../../components/Discussion";
import { getTopicTranslation } from "../../../i18n/topicsUtils";
import SchemaMarkup from "../../../components/seo/SchemaMarkup.astro";
import { createT, getLocalizedPath } from "../../../i18n/index";
import FatefulDeckMiniPromo from "../../../components/promo/FatefulDeckMiniPromo.astro";

const LOCALE_CONFIG = {
  en: { suffix: "-en", name: "English", dateLocale: "en-US" },
  "zh-CN": { suffix: "", name: "简体中文", dateLocale: "zh-CN" },
  "zh-TW": { suffix: "-tw", name: "繁體中文", dateLocale: "zh-TW" },
  ja: { suffix: "-ja", name: "日本語", dateLocale: "ja-JP" },
  fr: { suffix: "-fr", name: "Français", dateLocale: "fr-FR" },
} as const;

type SupportedLocale = keyof typeof LOCALE_CONFIG;

export async function getStaticPaths() {
  const LOCALE_CONFIG_INTERNAL = {
    en: { suffix: "-en", name: "English", dateLocale: "en-US" },
    "zh-TW": { suffix: "-tw", name: "繁體中文", dateLocale: "zh-TW" },
    ja: { suffix: "-ja", name: "日本語", dateLocale: "ja-JP" },
    fr: { suffix: "-fr", name: "Français", dateLocale: "fr-FR" },
  } as const;
  type LocaleKey = keyof typeof LOCALE_CONFIG_INTERNAL;

  const papers = await getCollection("papers");
  const pathList = [];
  const locales: LocaleKey[] = ["en", "zh-TW", "ja", "fr"];

  for (const locale of locales) {
    const suf = LOCALE_CONFIG_INTERNAL[locale].suffix;
    const filtered = papers.filter((p) => p.slug.endsWith(suf));

    for (const p of filtered) {
      let clean = p.slug;
      if (suf && clean.endsWith(suf)) clean = clean.slice(0, -suf.length);
      pathList.push({
        params: { locale, slug: clean },
        props: { paper: p, locale },
      });
    }
  }
  return pathList;
}

const { paper, locale } = Astro.props;
const currentLocale = locale as SupportedLocale;
const config = LOCALE_CONFIG[currentLocale];
const t = createT(currentLocale);
const { Content } = await paper.render();

// Related Papers
const allPapers = await getCollection("papers");
const relatedPapers = allPapers
  .filter(
    (p) =>
      p.slug !== paper.slug &&
      p.slug.endsWith(config.suffix) &&
      p.data.topics.some((topic) => paper.data.topics.includes(topic)),
  )
  .slice(0, 3);

// Helpers
const formatDate = (date: Date) => {
  return date.toLocaleDateString(config.dateLocale, {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};

const formatCitations = (count?: number) => {
  if (!count) return "0";
  if (count >= 1000) return (count / 1000).toFixed(1) + "K";
  return count.toString();
};

const homeLink = getLocalizedPath("/", currentLocale);
const papersLink = getLocalizedPath("papers", currentLocale);

function cleanSlug(slug: string) {
  const suf = config.suffix;
  if (suf && slug.endsWith(suf)) return slug.slice(0, -suf.length);
  return slug;
}
---

<Layout
  title={`${paper.data.title} - FemRes`}
  description={paper.data.description}
>
  <SchemaMarkup slot="head" type="ScholarlyArticle" data={paper.data} />
  <article class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumb -->
    <nav class="mb-8">
      <div
        class="flex items-center space-x-2 text-sm text-gray-500 dark:text-gray-400"
      >
        <a
          href={homeLink}
          class="hover:text-amber-600 dark:hover:text-amber-400"
          >{t("nav.home")}</a
        >
        <span>/</span>
        <a
          href={papersLink}
          class="hover:text-amber-600 dark:hover:text-amber-400"
          >{t("nav.papers")}</a
        >
        <span>/</span>
        <span class="text-gray-900 dark:text-white line-clamp-1"
          >{paper.data.title}</span
        >
      </div>
    </nav>

    <!-- Header -->
    <header class="mb-12">
      <h1
        class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white mb-3 leading-tight"
      >
        {paper.data.title}
      </h1>

      {
        paper.data.originalTitle && (
          <h2 class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 mb-6 font-medium italic">
            {paper.data.originalTitle}
          </h2>
        )
      }

      <!-- Meta Info -->
      <div
        class="flex flex-wrap items-center gap-4 text-sm text-gray-600 dark:text-gray-400 mb-6"
      >
        <div class="flex items-center">
          <svg
            class="w-4 h-4 mr-2"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
            ></path>
          </svg>
          <span class="font-medium">{paper.data.author}</span>
        </div>

        <div class="flex items-center">
          <svg
            class="w-4 h-4 mr-2"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
            ></path>
          </svg>
          <time datetime={paper.data.publishDate.toISOString()}>
            {formatDate(paper.data.publishDate)}
          </time>
        </div>

        {
          paper.data.journal && (
            <div class="flex items-center">
              <svg
                class="w-4 h-4 mr-2"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"
                />
              </svg>
              <span>{paper.data.journal}</span>
            </div>
          )
        }

        {
          paper.data.citationCount && (
            <div class="flex items-center">
              <svg
                class="w-4 h-4 mr-2"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
                />
              </svg>
              <span>
                {formatCitations(paper.data.citationCount)}{" "}
                {t("paper.citationCount")}
              </span>
            </div>
          )
        }
      </div>

      <!-- Description -->
      <div
        class="bg-gradient-to-r from-amber-50 to-orange-50 dark:from-amber-900/30 dark:to-orange-900/30 rounded-xl p-6 mb-8"
      >
        <p class="text-gray-700 dark:text-gray-300 leading-relaxed text-lg">
          {paper.data.description}
        </p>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main Content -->
      <div class="lg:col-span-2">
        <div class="mb-8">
          <div
            class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6 space-y-6"
          >
            <!-- Abstract -->
            {
              paper.data.abstract && (
                <div>
                  <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
                    <span class="text-amber-600 dark:text-amber-400 mr-3">
                      📋
                    </span>
                    {t("paper.abstract")}
                  </h2>
                  <div class="text-gray-700 dark:text-gray-300 leading-relaxed whitespace-pre-line">
                    {paper.data.abstract}
                  </div>
                </div>
              )
            }

            <!-- Keywords -->
            {
              paper.data.keywords && paper.data.keywords.length > 0 && (
                <div>
                  <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
                    <span class="text-amber-600 dark:text-amber-400 mr-3">
                      🔑
                    </span>
                    {t("paper.keywords")}
                  </h2>
                  <div class="flex flex-wrap gap-2">
                    {paper.data.keywords.map((keyword) => (
                      <span class="inline-block px-3 py-1 bg-indigo-50 dark:bg-indigo-900/30 border border-indigo-200 dark:border-indigo-700 text-indigo-700 dark:text-indigo-300 rounded-full text-sm">
                        {keyword}
                      </span>
                    ))}
                  </div>
                </div>
              )
            }

            <!-- Topics -->
            <div>
              <h2
                class="text-xl font-semibold text-gray-900 dark:text-white mb-4 flex items-center"
              >
                <span class="text-amber-600 dark:text-amber-400 mr-3">🏷️</span>
                {t("papersPage.topicsTitle")}
              </h2>
              <div class="flex flex-wrap gap-2">
                {
                  paper.data.topics.map((topic) => (
                    <a
                      href={getLocalizedPath(
                        `topics/${encodeURIComponent(topic)}`,
                        currentLocale,
                      )}
                      class="inline-block px-3 py-1 bg-purple-50 dark:bg-purple-900/30 border border-purple-200 dark:border-purple-700 text-purple-700 dark:text-purple-300 rounded-full text-sm hover:bg-purple-100 dark:hover:bg-purple-900/50 transition-colors"
                    >
                      #{getTopicTranslation(topic, currentLocale as any)}
                    </a>
                  ))
                }
              </div>
            </div>
          </div>
        </div>

        <!-- Action Buttons -->
        <div
          class="flex items-center justify-between py-6 border-y border-gray-200 dark:border-gray-700 mb-8"
        >
          <div class="flex items-center">
            <InteractionButtons
              contentId={`paper-${paper.slug}`}
              contentType="paper"
              client:load
              t={{
                like: t("interactions.like"),
                unlike: t("interactions.unlike"),
                bookmark: t("interactions.bookmark"),
                unbookmark: t("interactions.unbookmark"),
                loginToInteract: t("interactions.loginToInteract"),
              }}
            />
          </div>

          <a
            href={paper.data.sourceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center px-4 py-2 bg-amber-600 hover:bg-amber-700 text-white text-sm font-medium rounded-lg transition-colors"
          >
            <svg
              class="w-4 h-4 mr-2"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
              ></path>
            </svg>
            {t("paper.viewPdf") || "View PDF"}
          </a>
        </div>

        <!-- Detailed Content -->
        <div
          class="prose prose-lg max-w-none
                      prose-headings:text-gray-900 dark:prose-headings:text-white
                      prose-p:text-gray-700 dark:prose-p:text-gray-300
                      prose-a:text-amber-600 hover:prose-a:text-amber-800
                      prose-strong:text-gray-900 dark:prose-strong:text-white
                      prose-blockquote:text-gray-700 dark:prose-blockquote:text-gray-300
                      prose-blockquote:border-amber-500
                      prose-code:text-amber-600 dark:prose-code:text-amber-400
                      prose-pre:bg-gray-800 dark:prose-pre:bg-gray-900 mb-8"
        >
          <Content />
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <div class="sticky top-20 space-y-6">
          <!-- Paper Info -->
          <div
            class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6"
          >
            <h3 class="font-semibold text-gray-900 dark:text-white mb-4">
              {t("paper.info")}
            </h3>

            <div class="space-y-3 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-500 dark:text-gray-400"
                  >{t("book.author")}:</span
                >
                <span class="text-gray-900 dark:text-white font-medium"
                  >{paper.data.author}</span
                >
              </div>

              <div class="flex justify-between">
                <span class="text-gray-500 dark:text-gray-400"
                  >{t("book.published")}:</span
                >
                <span class="text-gray-900 dark:text-white"
                  >{formatDate(paper.data.publishDate)}</span
                >
              </div>

              {
                paper.data.journal && (
                  <div class="flex justify-between">
                    <span class="text-gray-500 dark:text-gray-400">
                      {t("paper.journal")}:
                    </span>
                    <span class="text-gray-900 dark:text-white">
                      {paper.data.journal}
                    </span>
                  </div>
                )
              }

              {
                paper.data.doi && (
                  <div class="flex justify-between">
                    <span class="text-gray-500 dark:text-gray-400">
                      {t("paper.doi")}:
                    </span>
                    <span class="text-gray-900 dark:text-white font-mono break-all">
                      {paper.data.doi}
                    </span>
                  </div>
                )
              }

              {
                paper.data.citationCount && (
                  <div class="flex justify-between">
                    <span class="text-gray-500 dark:text-gray-400">
                      {t("paper.citationCount")}:
                    </span>
                    <span class="text-gray-900 dark:text-white">
                      {formatCitations(paper.data.citationCount)}
                    </span>
                  </div>
                )
              }

              <div class="flex justify-between">
                <span class="text-gray-500 dark:text-gray-400"
                  >{t("paper.language")}:</span
                >
                <span class="text-gray-900 dark:text-white">
                  {
                    paper.data.contentLanguage === "zh-CN"
                      ? t("languages.zh-CN")
                      : paper.data.contentLanguage === "en"
                        ? t("languages.en")
                        : paper.data.contentLanguage
                  }
                </span>
              </div>
            </div>
          </div>

          <!-- Related Papers -->
          {
            relatedPapers.length > 0 && (
              <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6">
                <h3 class="font-semibold text-gray-900 dark:text-white mb-4">
                  {t("paper.relatedPapers")}
                </h3>
                <div class="space-y-4">
                  {relatedPapers.map((relatedPaper) => (
                    <a
                      href={getLocalizedPath(
                        `papers/${cleanSlug(relatedPaper.slug)}`,
                        currentLocale,
                      )}
                      class="group block hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg p-2 transition-colors"
                    >
                      <h4 class="font-medium text-gray-900 dark:text-white text-sm leading-tight mb-1 group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors line-clamp-2">
                        {relatedPaper.data.title}
                      </h4>
                      <p class="text-xs text-gray-600 dark:text-gray-400 mb-1">
                        {relatedPaper.data.author}
                      </p>
                      <p class="text-xs text-gray-500 dark:text-gray-500">
                        {relatedPaper.data.journal || "Academic"}
                      </p>
                    </a>
                  ))}
                </div>
              </div>
            )
          }

          <!-- Buy Me a Coffee -->
          <div
            class="bg-gradient-to-br from-yellow-50 to-orange-50 dark:from-yellow-900/20 dark:to-orange-900/20 rounded-xl p-6 shadow-sm border border-yellow-200 dark:border-yellow-800/30"
          >
            <h3
              class="font-semibold text-gray-900 dark:text-white mb-3 text-center"
            >
              {t("video.supportUs")}
            </h3>
            <p
              class="text-sm text-gray-600 dark:text-gray-400 mb-4 text-center"
            >
              {t("video.supportMessage")}
            </p>
            <a
              href="https://buymeacoffee.com/femres"
              target="_blank"
              rel="noopener noreferrer"
              class="block w-full px-4 py-3 bg-gradient-to-r from-yellow-400 to-orange-500 hover:from-yellow-500 hover:to-orange-600 text-white font-semibold rounded-lg transition-all duration-200 text-center"
            >
              {t("contribute.support.button")}
            </a>
          </div>

          <FatefulDeckMiniPromo className="mt-8" />
        </div>
      </div>
    </div>
  </article>

  <!-- Newsletter/Share Section -->
  <section class="border-t border-gray-200 dark:border-gray-700 pt-12 mt-16">
    <div class="bg-gray-100 dark:bg-gray-800/50 rounded-2xl p-8 text-center">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">
        {t("newsletter.title")}
      </h2>
      <p class="text-gray-600 dark:text-gray-300 mb-6">
        {t("newsletter.description")}
      </p>
      <form
        id="newsletter-form"
        class="flex flex-col sm:flex-row gap-4 justify-center"
        data-message-success={t("newsletter.success")}
        data-message-error={t("newsletter.error")}
        data-message-generic-error={t("newsletter.genericError")}
      >
        <input
          type="email"
          name="email"
          placeholder={t("auth.emailPlaceholder")}
          required
          class="px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-purple-500 focus:border-transparent outline-none min-w-[300px]"
        />
        <button
          type="submit"
          class="px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white font-bold rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        >
          {t("common.subscribe")}
        </button>
      </form>
      <p id="newsletter-message" class="mt-4 text-sm hidden"></p>
    </div>
  </section>

  <script>
    const form = document.getElementById(
      "newsletter-form",
    ) as HTMLFormElement | null;
    const messageEl = document.getElementById("newsletter-message");

    if (form) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const emailInput = form.querySelector(
          'input[name="email"]',
        ) as HTMLInputElement;
        const button = form.querySelector("button");
        if (!emailInput || !button) return;

        const email = emailInput.value;
        const successMsg = form.dataset.messageSuccess || null;
        const errorMsg = form.dataset.messageError || null;
        const genericMsg = form.dataset.messageGenericError || null;

        // Disable button
        button.disabled = true;
        const originalText = button.textContent;
        button.textContent = "...";

        try {
          const response = await fetch("/api/subscribe", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email, source: "paper_detail" }),
          });

          const data = await response.json();

          if (data.success) {
            if (messageEl) {
              messageEl.textContent = successMsg;
              messageEl.className =
                "mt-4 text-sm text-green-600 dark:text-green-400 font-medium";
              messageEl.classList.remove("hidden");
            }
            form.reset();
          } else {
            if (messageEl) {
              messageEl.textContent = errorMsg;
              messageEl.className =
                "mt-4 text-sm text-red-600 dark:text-red-400 font-medium";
              messageEl.classList.remove("hidden");
            }
          }
        } catch (error) {
          if (messageEl) {
            messageEl.textContent = genericMsg;
            messageEl.className =
              "mt-4 text-sm text-red-600 dark:text-red-400 font-medium";
            messageEl.classList.remove("hidden");
          }
        } finally {
          button.disabled = false;
          button.textContent = originalText;
        }
      });
    }
  </script>

  <Discussion
    contentId={`paper-${paper.slug}`}
    contentType="paper"
    locale={currentLocale}
    client:load
  />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
