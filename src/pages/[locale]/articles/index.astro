---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import ArticleCard from "../../../components/ArticleCard.astro";
import ArticleCard2 from "../../../components/ArticleCard2.astro";
import PageHeader from "../../../components/PageHeader.astro";
import Pagination from "../../../components/Pagination.astro";
import { createT } from "../../../i18n/index";
import {
  getTopicTranslation,
  findTopicByName,
} from "../../../i18n/topicsUtils";

// Define supported locales and their content suffixes
const LOCALE_CONFIG = {
  en: { suffix: "-en", name: "English" },
  "zh-CN": { suffix: "", name: "简体中文" },
  "zh-TW": { suffix: "-tw", name: "繁體中文" },
  ja: { suffix: "-ja", name: "日本語" },
  fr: { suffix: "-fr", name: "Français" },
} as const;

type SupportedLocale = keyof typeof LOCALE_CONFIG;

// Generate static paths for all supported locales
export function getStaticPaths() {
  const locales = ["en", "zh-CN", "zh-TW", "ja", "fr"];
  return locales.map((locale) => ({
    params: { locale },
  }));
}

// Get locale from params
const { locale } = Astro.params;
const currentLocale = locale as SupportedLocale;
const localeConfig = LOCALE_CONFIG[currentLocale];
const t = createT(currentLocale);

const articles = await getCollection("articles");

// Filter articles based on locale suffix
const publishedArticles = articles.filter((article) => {
  const isPublished = article.data.status === "published";
  if (!isPublished) return false;

  if (currentLocale === "zh-CN") {
    return (
      !article.slug.endsWith("-en") &&
      !article.slug.endsWith("-tw") &&
      !article.slug.endsWith("-ja") &&
      !article.slug.endsWith("-fr")
    );
  }

  return article.slug.endsWith(localeConfig.suffix);
});

// Sort by publish date
const sortedArticles = publishedArticles.sort((a, b) => {
  return (
    new Date(b.data.publishDate).getTime() -
    new Date(a.data.publishDate).getTime()
  );
});

// Get all topic tags
const allTopics = [
  ...new Set(publishedArticles.flatMap((article) => article.data.topics)),
].sort();

// Pagination settings
const ARTICLES_PER_PAGE = 12;
const totalArticles = publishedArticles.length;
const totalPages = Math.ceil(totalArticles / ARTICLES_PER_PAGE);

// Get current page number
const currentPage = Number(Astro.url.searchParams.get("page") || "1");
const validPage = Math.max(1, Math.min(currentPage, totalPages));

// Calculate current page articles
const startIndex = (validPage - 1) * ARTICLES_PER_PAGE;
const endIndex = startIndex + ARTICLES_PER_PAGE;
const currentPageArticles = sortedArticles.slice(startIndex, endIndex);

// Enrich articles with types (heuristic)
const enrichedArticles = currentPageArticles.map((article) => {
  let articleType: "news" | "blog" | "research" | "opinion" | "analysis" =
    "blog";
  const title = article.data.title.toLowerCase();
  if (
    title.includes("分析") ||
    title.includes("研究") ||
    title.includes("analysis") ||
    title.includes("research")
  ) {
    articleType = "research";
  }
  return { ...article, articleType };
});

// Clean slug by removing locale suffix
function cleanSlug(slug: string): string {
  const suffixes = ["-en", "-tw", "-ja", "-fr"];
  for (const suffix of suffixes) {
    if (slug.endsWith(suffix)) {
      return slug.slice(0, -suffix.length);
    }
  }
  return slug;
}

// Base URL for pagination
const baseUrl = `/${currentLocale}/articles`;
---

<Layout
  title={`${t("nav.articles")} - FemRes`}
  description={t("articlesPage.subtitle")}
>
  <div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <!-- Page Header -->
    <PageHeader
      title={t("nav.articles")}
      description={t("articlesPage.subtitle")}
      icon="📰"
      gradient="blue"
      stats={[
        {
          icon: "📝",
          text: t("articlesPage.stats.totalArticles", { count: totalArticles }),
        },
        {
          icon: "🏷️",
          text: t("articlesPage.stats.topicCategories", {
            count: allTopics.length,
          }),
        },
      ]}
    />

    <!-- Main Content -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <!-- Topic Filter -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
          {t("articlesPage.topicsTitle")}
        </h2>
        <div class="relative">
          <div
            id="topics-container"
            class="flex flex-wrap gap-3 overflow-hidden transition-all duration-300"
            style="max-height: 90px;"
          >
            <button
              class="filter-btn inline-flex items-center px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors text-sm font-medium"
              data-filter="all"
            >
              {t("articlesPage.allArticles")}
            </button>
            {
              allTopics.map((topic) => {
                const topicInfo = findTopicByName(topic);
                const translatedTopic = topicInfo
                  ? getTopicTranslation(topic, currentLocale as any)
                  : topic;
                return (
                  <button
                    class="filter-btn inline-flex items-center px-4 py-2 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 rounded-lg hover:border-purple-500 dark:hover:border-purple-400 hover:text-purple-600 dark:hover:text-purple-400 transition-colors text-sm"
                    data-filter={topic}
                  >
                    {translatedTopic}
                  </button>
                );
              })
            }
          </div>

          <!-- Expand/Collapse Button -->
          {
            allTopics.length > 20 && (
              <div class="text-center mt-4">
                <button
                  id="toggle-topics"
                  class="inline-flex items-center px-4 py-2 text-purple-600 dark:text-purple-400 hover:text-purple-800 dark:hover:text-purple-200 transition-colors text-sm font-medium"
                >
                  <span id="toggle-text">{t("booksPage.topics.showMore")}</span>
                  <svg
                    id="toggle-icon"
                    class="ml-2 w-4 h-4 transform transition-transform duration-200"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M19 9l-7 7-7-7"
                    />
                  </svg>
                </button>
              </div>
            )
          }
        </div>
      </div>

      <!-- Article List -->
      <div class="mb-12">
        <div class="flex items-center justify-between mb-8">
          <div>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
              <span id="current-filter"
                >{t("articlesPage.allArticlesHeading")}</span
              >
              <span
                id="article-count"
                class="text-base font-normal text-gray-600 dark:text-gray-400 ml-2"
              >
                ({t("common.itemsCount", { count: totalArticles })})
              </span>
            </h2>
          </div>
          <div class="flex items-center gap-4">
            <select
              id="sort-select"
              class="px-3 py-2 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg text-sm text-gray-900 dark:text-white"
            >
              <option value="date-desc">{t("articlesPage.sort.latest")}</option>
              <option value="date-asc">{t("articlesPage.sort.oldest")}</option>
              <option value="title-asc">{t("articlesPage.sort.titleAZ")}</option
              >
              <option value="title-desc"
                >{t("articlesPage.sort.titleZA")}</option
              >
            </select>
          </div>
        </div>

        <!-- Articles Grid -->
        <div id="articles-grid" class="space-y-8">
          {
            enrichedArticles.length > 0 && (
              <div
                class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8"
                id="featured-grid"
              >
                {enrichedArticles.slice(0, 2).map((article) => (
                  <div
                    class="article-item"
                    data-topics={JSON.stringify(article.data.topics)}
                  >
                    <ArticleCard
                      title={article.data.title}
                      author={article.data.author}
                      description={article.data.description}
                      featuredImage={article.data.featuredImage}
                      publishDate={article.data.publishDate}
                      readingTime={article.data.readingTime}
                      sourceUrl={article.data.sourceUrl}
                      slug={cleanSlug(article.slug)}
                      topics={article.data.topics}
                      articleType={article.articleType}
                      locale={currentLocale}
                    />
                  </div>
                ))}
              </div>
            )
          }

          {
            enrichedArticles.length > 2 && (
              <div class="space-y-6" id="standard-list">
                {enrichedArticles.slice(2).map((article) => (
                  <div
                    class="article-item"
                    data-topics={JSON.stringify(article.data.topics)}
                  >
                    <ArticleCard2
                      title={article.data.title}
                      author={article.data.author}
                      description={article.data.description}
                      featuredImage={article.data.featuredImage}
                      publishDate={article.data.publishDate}
                      readingTime={article.data.readingTime}
                      sourceUrl={article.data.sourceUrl}
                      slug={cleanSlug(article.slug)}
                      topics={article.data.topics}
                      articleType={article.articleType}
                      locale={currentLocale}
                    />
                  </div>
                ))}
              </div>
            )
          }

          {
            totalArticles === 0 && (
              <div class="text-center py-16">
                <p class="text-gray-500 dark:text-gray-400">
                  {t("articlesPage.noArticles")}
                </p>
              </div>
            )
          }
        </div>

        <!-- Pagination -->
        {
          totalPages > 1 && (
            <div id="original-pagination" class="flex justify-center mt-12">
              <Pagination
                currentPage={validPage}
                totalPages={totalPages}
                baseUrl={baseUrl}
                locale={currentLocale as any}
              />
            </div>
          )
        }
        <div id="dynamic-pagination" class="flex justify-center mt-12"></div>
      </div>

      <!-- Reading Guide Section -->
      <div
        class="mt-16 bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-8"
      >
        <div class="text-center">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">
            📖 {t("articlesPage.guide.title")}
          </h2>
          <div class="grid md:grid-cols-3 gap-6 text-left mt-8">
            <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm">
              <div class="text-2xl mb-3">🔍</div>
              <h3 class="font-semibold text-gray-900 dark:text-white mb-2">
                {t("articlesPage.guide.deepReading.title")}
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                {t("articlesPage.guide.deepReading.description")}
              </p>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm">
              <div class="text-2xl mb-3">🌐</div>
              <h3 class="font-semibold text-gray-900 dark:text-white mb-2">
                {t("articlesPage.guide.intersectionalPerspective.title")}
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                {t("articlesPage.guide.intersectionalPerspective.description")}
              </p>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm">
              <div class="text-2xl mb-3">🧠</div>
              <h3 class="font-semibold text-gray-900 dark:text-white mb-2">
                {t("articlesPage.guide.criticalThinking.title")}
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                {t("articlesPage.guide.criticalThinking.description")}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<!-- Pass data to client -->
<script
  is:inline
  define:vars={{
    allArticlesData: sortedArticles.map((article) => ({
      slug: cleanSlug(article.slug),
      title: article.data.title,
      author: article.data.author,
      description: article.data.description,
      featuredImage: article.data.featuredImage,
      publishDate: article.data.publishDate.toISOString(),
      topics: article.data.topics,
      readingTime: article.data.readingTime,
      sourceUrl: article.data.sourceUrl,
    })),
    topicTranslations: Object.fromEntries(
      allTopics.map((topic) => {
        const topicInfo = findTopicByName(topic);
        return [
          topic,
          topicInfo ? getTopicTranslation(topic, currentLocale as any) : topic,
        ];
      }),
    ),
    i18n: {
      allArticles: t("articlesPage.allArticles"),
      allArticlesHeading: t("articlesPage.allArticlesHeading"),
      showMore: t("booksPage.topics.showMore"),
      showLess: t("booksPage.topics.showLess"),
      countFormat: t("articlesPage.articlesCount"),
      readTimeFormat: t("common.readTimeFormat"),
      readTimeFormatShort: t("common.readTimeFormatShort"),
    },
    currentLocale: currentLocale,
  }}
>
  window.ALL_ARTICLES_DATA = allArticlesData;
  window.TOPIC_TRANSLATIONS = topicTranslations;
  window.I18N = i18n;
  window.CURRENT_LOCALE = currentLocale;
</script>

<script>
  import type { Article } from "../../../i18n/types";

  function initPage() {
    const filterBtns = document.querySelectorAll(".filter-btn");
    const sortSelect = document.getElementById("sort-select");
    const articleCount = document.getElementById("article-count");
    const articlesGrid = document.getElementById("articles-grid");
    const topicsContainer = document.getElementById("topics-container");
    const toggleBtn = document.getElementById("toggle-topics");
    const toggleText = document.getElementById("toggle-text");
    const toggleIcon = document.getElementById("toggle-icon");

    let currentTopic = "all";
    const ARTICLES_PER_PAGE = 12;
    let currentPage = 1;

    const allArticleItems = (window.ALL_ARTICLES_DATA || []) as Article[];

    // Toggle topics
    let isTopicsExpanded = false;
    if (toggleBtn && topicsContainer) {
      toggleBtn.addEventListener("click", () => {
        isTopicsExpanded = !isTopicsExpanded;
        if (isTopicsExpanded) {
          topicsContainer.style.maxHeight = "none";
          if (toggleText) toggleText.textContent = window.I18N.showLess;
          if (toggleIcon) toggleIcon.style.transform = "rotate(180deg)";
        } else {
          topicsContainer.style.maxHeight = "90px";
          if (toggleText) toggleText.textContent = window.I18N.showMore;
          if (toggleIcon) toggleIcon.style.transform = "rotate(0deg)";
        }
      });
    }

    // Filter functionality
    filterBtns.forEach((button) => {
      button.addEventListener("click", (e) => {
        const target = e.currentTarget as HTMLElement;
        const filterValue = target.dataset.filter || "all";
        currentTopic = filterValue;
        currentPage = 1;

        filterBtns.forEach((btn) => {
          btn.classList.remove("bg-purple-600", "text-white");
          btn.classList.add(
            "bg-white",
            "dark:bg-gray-800",
            "border",
            "border-gray-300",
            "dark:border-gray-600",
            "text-gray-700",
            "dark:text-gray-300",
          );
        });
        target.classList.remove(
          "bg-white",
          "dark:bg-gray-800",
          "border",
          "border-gray-300",
          "dark:border-gray-600",
          "text-gray-700",
          "dark:text-gray-300",
        );
        target.classList.add("bg-purple-600", "text-white");

        filterAndSort();
      });
    });

    // Sort functionality
    if (sortSelect) {
      sortSelect.addEventListener("change", function () {
        currentPage = 1;
        filterAndSort();
      });
    }

    function filterAndSort() {
      const sortValue = (sortSelect as HTMLSelectElement)?.value || "date-desc";

      let filteredArticles = allArticleItems.filter((item: Article) => {
        if (currentTopic === "all") return true;
        return item.topics.includes(currentTopic);
      });

      filteredArticles.sort((a: Article, b: Article) => {
        switch (sortValue) {
          case "date-desc":
            return (
              new Date(b.publishDate).getTime() -
              new Date(a.publishDate).getTime()
            );
          case "date-asc":
            return (
              new Date(a.publishDate).getTime() -
              new Date(b.publishDate).getTime()
            );
          case "title-asc":
            return a.title.localeCompare(b.title);
          case "title-desc":
            return b.title.localeCompare(a.title);
          default:
            return 0;
        }
      });

      const totalFiltered = filteredArticles.length;
      const totalPages = Math.ceil(totalFiltered / ARTICLES_PER_PAGE);
      const startIndex = (currentPage - 1) * ARTICLES_PER_PAGE;
      const endIndex = startIndex + ARTICLES_PER_PAGE;
      const currentPageItems: Article[] = filteredArticles.slice(
        startIndex,
        endIndex,
      );

      // Update Grid - Force a clean simple grid for results
      if (articlesGrid) {
        articlesGrid.className =
          "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8";
        articlesGrid.innerHTML = "";

        currentPageItems.forEach((article) => {
          const card = createArticleCard(article);
          articlesGrid.appendChild(card);
        });
      }

      // Update Title & Count
      const currentFilter = document.getElementById("current-filter");
      const translatedTopic =
        currentTopic === "all"
          ? window.I18N.allArticlesHeading
          : window.TOPIC_TRANSLATIONS[currentTopic] || currentTopic;
      if (currentFilter) currentFilter.textContent = translatedTopic;
      if (articleCount)
        articleCount.innerText = `(${window.I18N.countFormat.replace("{count}", totalFiltered)})`;

      // Update Pagination
      const originalPagination = document.getElementById("original-pagination");
      if (originalPagination) originalPagination.style.display = "none";

      createDynamicPagination(totalPages);
    }

    function createDynamicPagination(totalPages: number) {
      const container = document.getElementById("dynamic-pagination");
      if (!container) return;
      container.innerHTML = "";
      if (totalPages <= 1) return;

      const nav = document.createElement("nav");
      nav.className = "flex items-center space-x-2";

      // Prev
      const prev = document.createElement("button");
      prev.className = `px-3 py-2 rounded-lg ${currentPage > 1 ? "bg-white dark:bg-gray-800" : "opacity-50 cursor-not-allowed"}`;
      prev.innerHTML =
        '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7" stroke-width="2"/></svg>';
      if (currentPage > 1)
        prev.onclick = () => {
          currentPage--;
          filterAndSort();
          window.scrollTo(0, 0);
        };
      nav.appendChild(prev);

      // Numbers
      for (let i = 1; i <= totalPages; i++) {
        if (i === 1 || i === totalPages || Math.abs(i - currentPage) <= 1) {
          const btn = document.createElement("button");
          btn.className = `px-4 py-2 rounded-lg ${i === currentPage ? "bg-purple-600 text-white" : "bg-white dark:bg-gray-800"}`;
          btn.textContent = i.toString();
          btn.onclick = () => {
            currentPage = i;
            filterAndSort();
            window.scrollTo(0, 0);
          };
          nav.appendChild(btn);
        } else if (i === 2 || i === totalPages - 1) {
          const dots = document.createElement("span");
          dots.textContent = "...";
          nav.appendChild(dots);
        }
      }

      // Next
      const next = document.createElement("button");
      next.className = `px-3 py-2 rounded-lg ${currentPage < totalPages ? "bg-white dark:bg-gray-800" : "opacity-50 cursor-not-allowed"}`;
      next.innerHTML =
        '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2"/></svg>';
      if (currentPage < totalPages)
        next.onclick = () => {
          currentPage++;
          filterAndSort();
          window.scrollTo(0, 0);
        };
      nav.appendChild(next);

      container.appendChild(nav);
    }

    function createArticleCard(article: Article) {
      const div = document.createElement("div");
      div.className = "article-item";
      const locale = window.CURRENT_LOCALE;
      div.innerHTML = `
        <a href="/${locale}/articles/${article.slug}" class="group block bg-white dark:bg-gray-800 rounded-xl shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden h-full">
          <div class="aspect-video overflow-hidden bg-gray-100 dark:bg-gray-700">
            <img src="${article.featuredImage}" alt="${article.title}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
          </div>
          <div class="p-6">
            <h3 class="font-bold text-gray-900 dark:text-white mb-2 line-clamp-2 group-hover:text-purple-600 transition-colors">${article.title}</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-3">${article.description}</p>
          </div>
        </a>
      `;
      return div;
    }
  }

  document.addEventListener("astro:page-load", initPage);
</script>
