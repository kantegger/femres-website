---
export const prerender = true;

import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import SchemaMarkup from "../../components/seo/SchemaMarkup.astro";
import InteractionButtons from "../../components/InteractionButtons";
import Discussion from "../../components/Discussion";
import { createT, formatDate } from "../../i18n/index";
import FatefulDeckMiniPromo from "../../components/promo/FatefulDeckMiniPromo.astro";
import { getTopicTranslation } from "../../i18n/topicsUtils";

const currentLocale = "zh-CN";
const t = createT(currentLocale);

export async function getStaticPaths() {
  const podcasts = await getCollection("podcasts");
  const filtered = podcasts.filter(
    (p) =>
      !p.slug.endsWith("-en") &&
      !p.slug.endsWith("-tw") &&
      !p.slug.endsWith("-ja") &&
      !p.slug.endsWith("-fr"),
  );

  return filtered.map((podcast) => ({
    params: { slug: podcast.slug },
    props: { podcast },
  }));
}

const { podcast } = Astro.props;
const { Content } = await podcast.render();

// Get related podcasts
const allPodcasts = await getCollection("podcasts");
const relatedPodcasts = allPodcasts
  .filter((p) => {
    const isDifferent = p.slug !== podcast.slug;
    const sameLocale =
      !p.slug.endsWith("-en") &&
      !p.slug.endsWith("-tw") &&
      !p.slug.endsWith("-ja") &&
      !p.slug.endsWith("-fr");
    const hasCommonTopic = p.data.topics.some((topic) =>
      podcast.data.topics.includes(topic),
    );
    return isDifferent && sameLocale && hasCommonTopic;
  })
  .slice(0, 3);

const formatDateLoc = (date: Date) => formatDate(date, currentLocale);
const homeLink = "/";
const podcastsLink = "/podcasts";

// Get platform info and embed URL
function getPlatformInfo(url: string) {
  if (url?.includes("spotify.com")) {
    const match = url.match(/show\/(\w+)/);
    const showId = match ? match[1] : "";
    return {
      name: "Spotify",
      embedUrl: showId
        ? `https://open.spotify.com/embed/show/${showId}?utm_source=generator`
        : null,
    };
  }
  if (url?.includes("apple.com/podcasts")) {
    return { name: "Apple Podcasts", embedUrl: null };
  }
  return { name: "Podcast", embedUrl: null };
}
const platform = getPlatformInfo(podcast.data.sourceUrl);

// Language display
const getLanguageDisplay = (lang: string) => {
  const langMap: Record<string, string> = {
    en: "英语",
    "zh-CN": "中文",
    "zh-TW": "中文",
    ja: "日语",
    fr: "法语",
  };
  return langMap[lang] || lang || "未知";
};
---

<Layout
  title={`${podcast.data.title} - FemRes`}
  description={podcast.data.description}
>
  <SchemaMarkup slot="head" type="PodcastEpisode" data={podcast.data} />
  <article class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumb -->
    <nav class="mb-8">
      <div
        class="flex items-center space-x-2 text-sm text-gray-500 dark:text-gray-400"
      >
        <a
          href={homeLink}
          class="hover:text-purple-600 dark:hover:text-purple-400"
          >{t("nav.home")}</a
        >
        <span>/</span>
        <a
          href={podcastsLink}
          class="hover:text-purple-600 dark:hover:text-purple-400"
          >{t("nav.podcasts")}</a
        >
        <span>/</span>
        <span class="text-gray-900 dark:text-white">{podcast.data.title}</span>
      </div>
    </nav>

    <!-- Header -->
    <header class="mb-12">
      <div class="flex items-center mb-4"></div>
      <h1
        class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white mb-6 leading-tight"
      >
        {podcast.data.title}
      </h1>

      <!-- Meta Info -->
      <div
        class="flex flex-wrap items-center gap-4 text-sm text-gray-600 dark:text-gray-400 mb-6"
      >
        <div class="flex items-center">
          <svg
            class="w-4 h-4 mr-2"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a2 2 0 012-2h2a2 2 0 012 2v3a3 3 0 01-3 3z"
            ></path>
          </svg>
          <span class="font-medium">{podcast.data.author}</span>
        </div>
        <div class="flex items-center">
          <svg
            class="w-4 h-4 mr-2"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
            ></path>
          </svg>
          <time datetime={podcast.data.publishDate.toISOString()}>
            {formatDateLoc(podcast.data.publishDate)}
          </time>
        </div>
      </div>

      <!-- Description -->
      <div
        class="bg-gradient-to-r from-purple-50 to-indigo-50 dark:from-purple-900/30 dark:to-indigo-900/30 rounded-xl p-6 mb-8"
      >
        <p class="text-gray-700 dark:text-gray-300 leading-relaxed text-lg">
          {podcast.data.description}
        </p>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main Content -->
      <div class="lg:col-span-2">
        <!-- Podcast Player -->
        <div class="mb-8">
          <div
            class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-sm border border-gray-200 dark:border-gray-700"
          >
            <h2
              class="text-xl font-semibold text-gray-900 dark:text-white mb-4 flex items-center"
            >
              <span class="text-purple-600 dark:text-purple-400 mr-3">🎧</span>
              {t("podcast.listenOnline")}
              <span
                class="ml-2 text-xs bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200 px-2 py-1 rounded"
              >
                {platform.name}
              </span>
            </h2>
            <div class="rounded-xl overflow-hidden">
              {
                platform.embedUrl ? (
                  <iframe
                    style="border-radius:12px"
                    src={platform.embedUrl}
                    width="100%"
                    height="352"
                    frameborder="0"
                    allowfullscreen
                    allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                    loading="lazy"
                    class="w-full"
                  />
                ) : (
                  <div class="bg-gradient-to-br from-purple-100 to-indigo-100 dark:from-purple-900/50 dark:to-indigo-900/50 rounded-xl p-8 text-center">
                    <div class="text-6xl mb-4">🎧</div>
                    <p class="text-gray-700 dark:text-gray-300 mb-4">
                      {t("podcast.visitSource")}
                    </p>
                    {podcast.data.sourceUrl && (
                      <a
                        href={podcast.data.sourceUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white font-semibold rounded-xl transition-colors"
                      >
                        <svg
                          class="w-5 h-5 mr-2"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                          />
                        </svg>
                        {t("common.listenNow")}
                      </a>
                    )}
                  </div>
                )
              }
            </div>
          </div>
        </div>

        <!-- Topics -->
        <div class="mb-8">
          <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">
            {t("common.topics")}
          </h2>
          <div class="flex flex-wrap gap-2">
            {
              podcast.data.topics.map((topic) => (
                <a
                  href={`/topics/${encodeURIComponent(topic)}`}
                  class="inline-block px-3 py-1 bg-purple-50 dark:bg-purple-900/30 border border-purple-200 dark:border-purple-700 text-purple-700 dark:text-purple-300 rounded-full text-sm hover:bg-purple-100 dark:hover:bg-purple-900/50 transition-colors"
                >
                  #{getTopicTranslation(topic, currentLocale as any)}
                </a>
              ))
            }
          </div>
        </div>

        <!-- Action Buttons -->
        <div
          class="flex items-center justify-between py-6 border-y border-gray-200 dark:border-gray-700 mb-8"
        >
          <div class="flex items-center">
            <InteractionButtons
              contentId={`podcast-${podcast.slug}`}
              contentType="podcast"
              client:visible
            />
          </div>
          {
            podcast.data.sourceUrl && (
              <a
                href={podcast.data.sourceUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium rounded-lg transition-colors"
              >
                <svg
                  class="w-4 h-4 mr-2"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                  />
                </svg>
                {t("common.listenPodcast")}
              </a>
            )
          }
        </div>

        <!-- Detailed Content -->
        <div
          class="prose prose-lg max-w-none
                     prose-headings:text-gray-900 dark:prose-headings:text-white
                     prose-p:text-gray-700 dark:prose-p:text-gray-300
                     prose-a:text-purple-600 hover:prose-a:text-purple-800
                     prose-strong:text-gray-900 dark:prose-strong:text-white
                     prose-blockquote:text-gray-700 dark:prose-blockquote:text-gray-300
                     prose-blockquote:border-purple-500
                     prose-code:text-purple-600 dark:prose-code:text-purple-400
                     prose-pre:bg-gray-800 dark:prose-pre:bg-gray-900"
        >
          <Content />
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <div class="sticky top-20 space-y-6">
          <!-- Podcast Info -->
          <div
            class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6"
          >
            <h3 class="font-semibold text-gray-900 dark:text-white mb-4">
              {t("podcast.info")}
            </h3>
            <div class="space-y-3 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-500 dark:text-gray-400"
                  >{t("podcast.host")}:</span
                >
                <span class="text-gray-900 dark:text-white font-medium"
                  >{podcast.data.author}</span
                >
              </div>
              {
                podcast.data.originalTitle && (
                  <div class="flex justify-between">
                    <span class="text-gray-500 dark:text-gray-400">
                      {t("podcast.originalName")}:
                    </span>
                    <span class="text-gray-900 dark:text-white font-medium">
                      {podcast.data.originalTitle}
                    </span>
                  </div>
                )
              }
              <div class="flex justify-between">
                <span class="text-gray-500 dark:text-gray-400"
                  >{t("podcast.added")}:</span
                >
                <span class="text-gray-900 dark:text-white"
                  >{formatDateLoc(podcast.data.publishDate)}</span
                >
              </div>
              {
                podcast.data.contentLanguage && (
                  <div class="flex justify-between">
                    <span class="text-gray-500 dark:text-gray-400">
                      {t("common.language")}:
                    </span>
                    <span class="text-gray-900 dark:text-white">
                      {getLanguageDisplay(podcast.data.contentLanguage)}
                    </span>
                  </div>
                )
              }
            </div>
          </div>

          <!-- Related Podcasts -->
          {
            relatedPodcasts.length > 0 && (
              <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6">
                <h3 class="font-semibold text-gray-900 dark:text-white mb-4">
                  {t("podcast.related")}
                </h3>
                <div class="space-y-4">
                  {relatedPodcasts.map((rel) => (
                    <a
                      href={`/podcasts/${rel.slug}`}
                      class="group flex gap-3 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg p-2 transition-colors"
                    >
                      <div class="flex-shrink-0 w-16 h-16 bg-gradient-to-br from-purple-100 to-indigo-100 dark:from-purple-900 dark:to-indigo-900 rounded-lg flex items-center justify-center">
                        {rel.data.thumbnail ? (
                          <img
                            src={rel.data.thumbnail}
                            alt={rel.data.title}
                            class="w-full h-full object-cover rounded-lg"
                          />
                        ) : (
                          <span class="text-2xl">🎧</span>
                        )}
                      </div>
                      <div class="flex-1 min-w-0">
                        <h4 class="font-medium text-gray-900 dark:text-white text-sm leading-tight mb-1 group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors line-clamp-2">
                          {rel.data.title}
                        </h4>
                        <p class="text-xs text-gray-600 dark:text-gray-400 mb-1">
                          {rel.data.author}
                        </p>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            )
          }

          <!-- Buy Me a Coffee -->
          <div
            class="bg-gradient-to-br from-yellow-50 to-orange-50 dark:from-yellow-900/20 dark:to-orange-900/20 rounded-xl p-6 shadow-sm border border-yellow-200 dark:border-yellow-800/30"
          >
            <h3
              class="font-semibold text-gray-900 dark:text-white mb-3 text-center"
            >
              {t("common.support")}
            </h3>
            <p
              class="text-sm text-gray-600 dark:text-gray-400 mb-4 text-center"
            >
              {t("common.supportMessage")}
            </p>
            <a
              href="https://buymeacoffee.com/femres"
              target="_blank"
              rel="noopener noreferrer"
              class="block w-full px-4 py-3 bg-gradient-to-r from-yellow-400 to-orange-500 hover:from-yellow-500 hover:to-orange-600 text-white font-semibold rounded-lg transition-all duration-200 text-center"
            >
              {t("contribute.support.button")}
            </a>
          </div>

          <FatefulDeckMiniPromo className="mt-8" />
        </div>
      </div>
    </div>
  </article>

  <!-- Newsletter/Share Section -->
  <section class="border-t border-gray-200 dark:border-gray-700 pt-12 mt-16">
    <div class="bg-gray-100 dark:bg-gray-800/50 rounded-2xl p-8 text-center">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">
        {t("newsletter.title")}
      </h2>
      <p class="text-gray-600 dark:text-gray-300 mb-6">
        {t("newsletter.description")}
      </p>
      <form
        id="newsletter-form"
        class="flex flex-col sm:flex-row gap-4 justify-center"
      >
        <input
          type="email"
          name="email"
          placeholder={t("auth.emailPlaceholder")}
          required
          class="px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-purple-500 focus:border-transparent outline-none min-w-[300px]"
        />
        <button
          type="submit"
          class="px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white font-bold rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        >
          {t("common.subscribe")}
        </button>
      </form>
      <p id="newsletter-message" class="mt-4 text-sm hidden"></p>
    </div>
  </section>

  <script>
    const form = document.getElementById(
      "newsletter-form",
    ) as HTMLFormElement | null;
    const messageEl = document.getElementById("newsletter-message");

    if (form) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const emailInput = form.querySelector(
          'input[name="email"]',
        ) as HTMLInputElement;
        const button = form.querySelector("button");
        if (!emailInput || !button) return;

        const email = emailInput.value;

        // Disable button
        button.disabled = true;
        const originalText = button.textContent;
        button.textContent = "...";

        try {
          const response = await fetch("/api/subscribe", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email, source: "podcast_detail" }),
          });

          const data = await response.json();

          if (data.success) {
            if (messageEl) {
              messageEl.textContent = "Subscribed successfully! / 订阅成功！";
              messageEl.className =
                "mt-4 text-sm text-green-600 dark:text-green-400 font-medium";
              messageEl.classList.remove("hidden");
            }
            form.reset();
          } else {
            if (messageEl) {
              messageEl.textContent =
                "Subscription failed. Please try again. / 订阅失败，请重试。";
              messageEl.className =
                "mt-4 text-sm text-red-600 dark:text-red-400 font-medium";
              messageEl.classList.remove("hidden");
            }
          }
        } catch (error) {
          if (messageEl) {
            messageEl.textContent = "An error occurred. / 发生错误。";
            messageEl.className =
              "mt-4 text-sm text-red-600 dark:text-red-400 font-medium";
            messageEl.classList.remove("hidden");
          }
        } finally {
          button.disabled = false;
          button.textContent = originalText;
        }
      });
    }
  </script>

  <!-- Discussion Section -->
  <Discussion
    contentId={`podcast-${podcast.slug}`}
    contentType="podcast"
    locale={currentLocale}
    client:load
  />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
