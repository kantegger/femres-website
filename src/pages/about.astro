---
import Layout from '../layouts/Layout.astro';
import { createT, getLocalizedPath } from '../i18n/index';

const currentLocale = 'zh-CN';
const t = createT(currentLocale);
---

<Layout title={`${t('about.title')} - FemRes`} description={t('about.subtitle')}>
  <!-- Hero Section -->
  <section class="relative py-12 sm:py-16 lg:py-20 overflow-hidden">
    <!-- Background decorative elements -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-10 left-10 w-32 sm:w-48 lg:w-64 h-32 sm:h-48 lg:h-64 bg-purple-300 rounded-full mix-blend-multiply filter blur-xl opacity-20 animate-blob"></div>
      <div class="absolute top-20 right-20 w-32 sm:w-48 lg:w-64 h-32 sm:h-48 lg:h-64 bg-pink-300 rounded-full mix-blend-multiply filter blur-xl opacity-20 animate-blob animation-delay-2000"></div>
      <div class="absolute bottom-10 left-1/2 w-32 sm:w-48 lg:w-64 h-32 sm:h-48 lg:h-64 bg-indigo-300 rounded-full mix-blend-multiply filter blur-xl opacity-20 animate-blob animation-delay-4000"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 dark:text-white mb-4 sm:mb-6">
          {t('about.title').replace(/FemRes/i, '').trim()}
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-pink-600">FemRes</span>
        </h1>
        <p class="text-lg sm:text-xl md:text-2xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto px-4">
          {t('about.subtitle')}
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <!-- Mission Section -->
    <section class="mb-16 sm:mb-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
        <div>
          <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4 sm:mb-6">
            {t('about.mission.title')}
          </h2>
          <p class="text-base sm:text-lg text-gray-600 dark:text-gray-300 mb-4 sm:mb-6 leading-relaxed">
            {t('about.mission.description1')}
          </p>
          <p class="text-base sm:text-lg text-gray-600 dark:text-gray-300 mb-6 leading-relaxed">
            {t('about.mission.description2')}
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <div class="flex items-center">
              <div class="w-10 h-10 sm:w-12 sm:h-12 bg-purple-100 dark:bg-purple-900 rounded-full flex items-center justify-center mr-3 flex-shrink-0">
                <span class="text-lg sm:text-xl">🌍</span>
              </div>
              <div>
                <div class="font-semibold text-gray-900 dark:text-white text-sm sm:text-base">{t('about.mission.globalPerspective')}</div>
                <div class="text-xs sm:text-sm text-gray-600 dark:text-gray-400">{t('about.mission.globalDescription')}</div>
              </div>
            </div>
            <div class="flex items-center">
              <div class="w-10 h-10 sm:w-12 sm:h-12 bg-pink-100 dark:bg-pink-900 rounded-full flex items-center justify-center mr-3 flex-shrink-0">
                <span class="text-lg sm:text-xl">✨</span>
              </div>
              <div>
                <div class="font-semibold text-gray-900 dark:text-white text-sm sm:text-base">{t('about.mission.curatedContent')}</div>
                <div class="text-xs sm:text-sm text-gray-600 dark:text-gray-400">{t('about.mission.curatedDescription')}</div>
              </div>
            </div>
          </div>
        </div>
        <div class="relative mt-8 lg:mt-0">
          <div class="aspect-square bg-gradient-to-br from-purple-100 to-pink-100 dark:from-purple-900 dark:to-pink-900 rounded-2xl p-6 sm:p-8 flex items-center justify-center">
            <div class="text-center">
              <div class="text-4xl sm:text-5xl lg:text-6xl mb-3 sm:mb-4">🤝</div>
              <p class="text-lg sm:text-xl lg:text-2xl font-bold text-gray-900 dark:text-white mb-2">{t('about.mission.values')}</p>
              <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400">{t('about.mission.buildBetter')}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Values Section -->
    <section class="mb-16 sm:mb-20">
      <div class="text-center mb-8 sm:mb-12">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-3 sm:mb-4">
          {t('about.coreValues.title')}
        </h2>
        <p class="text-lg sm:text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto px-4">
          {t('about.coreValues.subtitle')}
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
          <div class="w-14 h-14 bg-gradient-to-br from-purple-500 to-purple-600 rounded-xl flex items-center justify-center text-white text-2xl mb-4">
            ⚖️
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">{t('about.coreValues.genderEquality.title')}</h3>
          <p class="text-gray-600 dark:text-gray-400">
            {t('about.coreValues.genderEquality.description')}
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
          <div class="w-14 h-14 bg-gradient-to-br from-pink-500 to-pink-600 rounded-xl flex items-center justify-center text-white text-2xl mb-4">
            🌈
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">{t('about.coreValues.intersectionality.title')}</h3>
          <p class="text-gray-600 dark:text-gray-400">
            {t('about.coreValues.intersectionality.description')}
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
          <div class="w-14 h-14 bg-gradient-to-br from-indigo-500 to-indigo-600 rounded-xl flex items-center justify-center text-white text-2xl mb-4">
            📚
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">{t('about.coreValues.knowledgeEmpowerment.title')}</h3>
          <p class="text-gray-600 dark:text-gray-400">
            {t('about.coreValues.knowledgeEmpowerment.description')}
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
          <div class="w-14 h-14 bg-gradient-to-br from-emerald-500 to-emerald-600 rounded-xl flex items-center justify-center text-white text-2xl mb-4">
            🤲
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">{t('about.coreValues.openInclusion.title')}</h3>
          <p class="text-gray-600 dark:text-gray-400">
            {t('about.coreValues.openInclusion.description')}
          </p>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="mb-20">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
          {t('about.features.title')}
        </h2>
        <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
          {t('about.features.subtitle')}
        </p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="relative group">
          <div class="absolute inset-0 bg-gradient-to-r from-purple-600 to-pink-600 rounded-2xl opacity-0 group-hover:opacity-10 transition-opacity"></div>
          <div class="relative bg-white dark:bg-gray-800 rounded-2xl p-8 border border-gray-200 dark:border-gray-700 hover:shadow-xl transition-shadow">
            <div class="text-4xl mb-4">🎯</div>
            <h3 class="text-2xl font-semibold text-gray-900 dark:text-white mb-4">{t('about.features.smartAggregation.title')}</h3>
            <p class="text-gray-600 dark:text-gray-400 mb-4">
              {t('about.features.smartAggregation.description')}
            </p>
            <ul class="space-y-2 text-gray-600 dark:text-gray-400">
              {(t('about.features.smartAggregation.features') as any).map((feature: string) => (
                <li class="flex items-start">
                  <span class="text-purple-500 mr-2">•</span>
                  {feature}
                </li>
              ))}
            </ul>
          </div>
        </div>
        <div class="relative group">
          <div class="absolute inset-0 bg-gradient-to-r from-pink-600 to-rose-600 rounded-2xl opacity-0 group-hover:opacity-10 transition-opacity"></div>
          <div class="relative bg-white dark:bg-gray-800 rounded-2xl p-8 border border-gray-200 dark:border-gray-700 hover:shadow-xl transition-shadow">
            <div class="text-4xl mb-4">🏷️</div>
            <h3 class="text-2xl font-semibold text-gray-900 dark:text-white mb-4">{t('about.features.preciseClassification.title')}</h3>
            <p class="text-gray-600 dark:text-gray-400 mb-4">
              {t('about.features.preciseClassification.description')}
            </p>
            <ul class="space-y-2 text-gray-600 dark:text-gray-400">
              {(t('about.features.preciseClassification.features') as any).map((feature: string) => (
                <li class="flex items-start">
                  <span class="text-pink-500 mr-2">•</span>
                  {feature}
                </li>
              ))}
            </ul>
          </div>
        </div>
        <div class="relative group">
          <div class="absolute inset-0 bg-gradient-to-r from-indigo-600 to-purple-600 rounded-2xl opacity-0 group-hover:opacity-10 transition-opacity"></div>
          <div class="relative bg-white dark:bg-gray-800 rounded-2xl p-8 border border-gray-200 dark:border-gray-700 hover:shadow-xl transition-shadow">
            <div class="text-4xl mb-4">🌐</div>
            <h3 class="text-2xl font-semibold text-gray-900 dark:text-white mb-4">{t('about.features.diverseContent.title')}</h3>
            <p class="text-gray-600 dark:text-gray-400 mb-4">
              {t('about.features.diverseContent.description')}
            </p>
            <ul class="space-y-2 text-gray-600 dark:text-gray-400">
              {(t('about.features.diverseContent.features') as any).map((feature: string) => (
                <li class="flex items-start">
                  <span class="text-indigo-500 mr-2">•</span>
                  {feature}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Content Types Section -->
    <section class="mb-20 bg-gradient-to-br from-purple-50 to-pink-50 dark:from-gray-800 dark:to-gray-900 rounded-3xl p-12">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
          {t('about.contentTypes.title')}
        </h2>
        <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
          {t('about.contentTypes.subtitle')}
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
        <a href={getLocalizedPath('books', currentLocale)} class="group text-center">
          <div class="w-20 h-20 mx-auto bg-white dark:bg-gray-800 rounded-2xl flex items-center justify-center text-3xl shadow-md group-hover:shadow-xl group-hover:-translate-y-1 transition-all">
            📚
          </div>
          <h3 class="mt-3 font-semibold text-gray-900 dark:text-white group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors">{t('about.contentTypes.books.title')}</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">{t('about.contentTypes.books.description')}</p>
        </a>
        <a href={getLocalizedPath('films', currentLocale)} class="group text-center">
          <div class="w-20 h-20 mx-auto bg-white dark:bg-gray-800 rounded-2xl flex items-center justify-center text-3xl shadow-md group-hover:shadow-xl group-hover:-translate-y-1 transition-all">
            🎬
          </div>
          <h3 class="mt-3 font-semibold text-gray-900 dark:text-white group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors">{t('about.contentTypes.films.title')}</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">{t('about.contentTypes.films.description')}</p>
        </a>
        <a href={getLocalizedPath('articles', currentLocale)} class="group text-center">
          <div class="w-20 h-20 mx-auto bg-white dark:bg-gray-800 rounded-2xl flex items-center justify-center text-3xl shadow-md group-hover:shadow-xl group-hover:-translate-y-1 transition-all">
            📰
          </div>
          <h3 class="mt-3 font-semibold text-gray-900 dark:text-white group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors">{t('about.contentTypes.articles.title')}</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">{t('about.contentTypes.articles.description')}</p>
        </a>
        <a href={getLocalizedPath('videos', currentLocale)} class="group text-center">
          <div class="w-20 h-20 mx-auto bg-white dark:bg-gray-800 rounded-2xl flex items-center justify-center text-3xl shadow-md group-hover:shadow-xl group-hover:-translate-y-1 transition-all">
            🎥
          </div>
          <h3 class="mt-3 font-semibold text-gray-900 dark:text-white group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors">{t('about.contentTypes.videos.title')}</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">{t('about.contentTypes.videos.description')}</p>
        </a>
        <a href={getLocalizedPath('podcasts', currentLocale)} class="group text-center">
          <div class="w-20 h-20 mx-auto bg-white dark:bg-gray-800 rounded-2xl flex items-center justify-center text-3xl shadow-md group-hover:shadow-xl group-hover:-translate-y-1 transition-all">
            🎧
          </div>
          <h3 class="mt-3 font-semibold text-gray-900 dark:text-white group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors">{t('about.contentTypes.podcasts.title')}</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">{t('about.contentTypes.podcasts.description')}</p>
        </a>
        <a href={getLocalizedPath('papers', currentLocale)} class="group text-center">
          <div class="w-20 h-20 mx-auto bg-white dark:bg-gray-800 rounded-2xl flex items-center justify-center text-3xl shadow-md group-hover:shadow-xl group-hover:-translate-y-1 transition-all">
            📄
          </div>
          <h3 class="mt-3 font-semibold text-gray-900 dark:text-white group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors">{t('about.contentTypes.papers.title')}</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">{t('about.contentTypes.papers.description')}</p>
        </a>
      </div>
    </section>

    <!-- Topics Section -->
    <section class="mb-20">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
          {t('about.coreTopics.title')}
        </h2>
        <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
          {t('about.coreTopics.subtitle')}
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
          <div class="flex items-center mb-3">
            <span class="text-2xl mr-3">💼</span>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{t('about.coreTopics.workplaceEquality.title')}</h3>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            {t('about.coreTopics.workplaceEquality.description')}
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
          <div class="flex items-center mb-3">
            <span class="text-2xl mr-3">🌸</span>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{t('about.coreTopics.bodilyAutonomy.title')}</h3>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            {t('about.coreTopics.bodilyAutonomy.description')}
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
          <div class="flex items-center mb-3">
            <span class="text-2xl mr-3">📚</span>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{t('about.coreTopics.educationRights.title')}</h3>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            {t('about.coreTopics.educationRights.description')}
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
          <div class="flex items-center mb-3">
            <span class="text-2xl mr-3">🗳️</span>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{t('about.coreTopics.politicalParticipation.title')}</h3>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            {t('about.coreTopics.politicalParticipation.description')}
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
          <div class="flex items-center mb-3">
            <span class="text-2xl mr-3">👨‍👩‍👧‍👦</span>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{t('about.coreTopics.familyRoles.title')}</h3>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            {t('about.coreTopics.familyRoles.description')}
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
          <div class="flex items-center mb-3">
            <span class="text-2xl mr-3">🛡️</span>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{t('about.coreTopics.genderViolence.title')}</h3>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            {t('about.coreTopics.genderViolence.description')}
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
          <div class="flex items-center mb-3">
            <span class="text-2xl mr-3">📺</span>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{t('about.coreTopics.mediaRepresentation.title')}</h3>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            {t('about.coreTopics.mediaRepresentation.description')}
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
          <div class="flex items-center mb-3">
            <span class="text-2xl mr-3">👩‍🎓</span>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{t('about.coreTopics.historicalFigures.title')}</h3>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            {t('about.coreTopics.historicalFigures.description')}
          </p>
        </div>
      </div>
    </section>

    <!-- Team Section -->
    <section class="mb-20">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
          {t('about.team.title')}
        </h2>
        <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
          {t('about.team.subtitle')}
        </p>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-2xl p-12 border border-gray-200 dark:border-gray-700">
        <div class="max-w-3xl mx-auto text-center">
          <div class="text-5xl mb-6">🤝</div>
          <p class="text-lg text-gray-600 dark:text-gray-300 mb-8 leading-relaxed">
            {t('about.team.description')}
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-left">
            <div class="flex items-start">
              <div class="w-10 h-10 bg-purple-100 dark:bg-purple-900 rounded-full flex items-center justify-center mr-3 flex-shrink-0">
                <span class="text-purple-600 dark:text-purple-400">✓</span>
              </div>
              <div>
                <h4 class="font-semibold text-gray-900 dark:text-white mb-1">{t('about.team.openSource.title')}</h4>
                <p class="text-sm text-gray-600 dark:text-gray-400">{t('about.team.openSource.description')}</p>
              </div>
            </div>
            <div class="flex items-start">
              <div class="w-10 h-10 bg-pink-100 dark:bg-pink-900 rounded-full flex items-center justify-center mr-3 flex-shrink-0">
                <span class="text-pink-600 dark:text-pink-400">✓</span>
              </div>
              <div>
                <h4 class="font-semibold text-gray-900 dark:text-white mb-1">{t('about.team.communityDriven.title')}</h4>
                <p class="text-sm text-gray-600 dark:text-gray-400">{t('about.team.communityDriven.description')}</p>
              </div>
            </div>
            <div class="flex items-start">
              <div class="w-10 h-10 bg-indigo-100 dark:bg-indigo-900 rounded-full flex items-center justify-center mr-3 flex-shrink-0">
                <span class="text-indigo-600 dark:text-indigo-400">✓</span>
              </div>
              <div>
                <h4 class="font-semibold text-gray-900 dark:text-white mb-1">{t('about.team.nonProfit.title')}</h4>
                <p class="text-sm text-gray-600 dark:text-gray-400">{t('about.team.nonProfit.description')}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Open Source Section -->
    <section class="mb-20">
      <div class="bg-gradient-to-br from-gray-900 to-gray-800 dark:from-black dark:to-gray-900 rounded-3xl p-8 sm:p-12 text-white">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-10">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-white/10 rounded-2xl mb-6">
              <svg class="w-8 h-8 text-purple-400" fill="currentColor" viewBox="0 0 24 24">
