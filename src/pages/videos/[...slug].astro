---
export const prerender = true;

import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import SchemaMarkup from "../../components/seo/SchemaMarkup.astro";
import InteractionButtons from "../../components/InteractionButtons";
import Discussion from "../../components/Discussion";
import {
  createT,
  getLocalizedPath,
  formatRelativeTime,
  formatDate,
} from "../../i18n/index";
import FatefulDeckMiniPromo from "../../components/promo/FatefulDeckMiniPromo.astro";
import { getTopicTranslation } from "../../i18n/topicsUtils";

const currentLocale = "zh-CN";
const t = createT(currentLocale);

export async function getStaticPaths() {
  const videos = await getCollection("videos");
  const chineseInterfaceVideos = videos.filter(
    (video) =>
      !video.slug.endsWith("-en") &&
      !video.slug.endsWith("-ja") &&
      !video.slug.endsWith("-fr") &&
      !video.slug.endsWith("-tw"),
  );
  return chineseInterfaceVideos.map((video) => ({
    params: { slug: video.slug },
    props: { video },
  }));
}

const { video } = Astro.props;
const { Content } = await video.render();

// Related videos
const allVideos = await getCollection("videos");
const relatedVideos = allVideos
  .filter((v) => {
    const isDifferent = v.slug !== video.slug;
    const sameLocale =
      !v.slug.endsWith("-en") &&
      !v.slug.endsWith("-tw") &&
      !v.slug.endsWith("-ja") &&
      !v.slug.endsWith("-fr");
    const hasCommonTopic = v.data.topics.some((topic) =>
      video.data.topics.includes(topic),
    );
    return isDifferent && sameLocale && hasCommonTopic;
  })
  .slice(0, 3);

const formatDateLoc = (date: Date) => formatDate(date, currentLocale);
const homeLink = "/";
const videosLink = "/videos";

// Helper for Video Platform
function getPlatform(url: string) {
  if (url.includes("youtube.com") || url.includes("youtu.be"))
    return { name: "YouTube", icon: "🎬", color: "bg-red-600" };
  if (url.includes("bilibili.com"))
    return { name: "Bilibili", icon: "📺", color: "bg-blue-400" };
  if (url.includes("ted.com"))
    return { name: "TED", icon: "💡", color: "bg-red-700" };
  return { name: "Video", icon: "🎥", color: "bg-gray-600" };
}
const platform = getPlatform(video.data.sourceUrl);

const formatDuration = (seconds: number) => {
  if (!seconds) return "";
  const hours = Math.floor(seconds / 3600);
  const mins = Math.floor((seconds % 3600) / 60);
  const secs = seconds % 60;
  if (hours > 0)
    return `${hours}:${mins.toString().padStart(2, "0")}:${secs.toString().padStart(2, "0")}`;
  return `${mins}:${secs.toString().padStart(2, "0")}`;
};
---

<Layout
  title={`${video.data.title} - FemRes`}
  description={video.data.description}
>
  <SchemaMarkup slot="head" type="VideoObject" data={video.data} />
  <article class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumb -->
    <nav
      class="mb-8 flex items-center space-x-2 text-sm text-gray-500 dark:text-gray-400"
    >
      <a
        href={homeLink}
        class="hover:text-purple-600 dark:hover:text-purple-400"
        >{t("nav.home")}</a
      >
      <span>/</span>
      <a
        href={videosLink}
        class="hover:text-purple-600 dark:hover:text-purple-400"
        >{t("nav.videos")}</a
      >
      <span>/</span>
      <span class="text-gray-900 dark:text-white line-clamp-1"
        >{video.data.title}</span
      >
    </nav>

    <!-- Header -->
    <header class="mb-12">
      <h1
        class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white mb-6 leading-tight"
      >
        {video.data.title}
      </h1>

      <!-- Meta -->
      <div
        class="flex flex-col lg:flex-row lg:items-center lg:justify-between bg-gray-50 dark:bg-gray-800 rounded-xl p-6 mb-8"
      >
        <div
          class="flex flex-col md:flex-row md:items-center space-y-3 md:space-y-0 md:space-x-8"
        >
          <div class="flex items-center text-gray-700 dark:text-gray-300">
            <svg
              class="w-5 h-5 mr-2"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
              ></path></svg
            >
            <span class="font-medium">{video.data.author}</span>
          </div>
          <div class="flex items-center text-gray-700 dark:text-gray-300">
            <svg
              class="w-5 h-5 mr-2"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
              ></path></svg
            >
            <time datetime={video.data.publishDate.toISOString()}
              >{formatDateLoc(video.data.publishDate)}</time
            >
          </div>
          {
            video.data.duration && (
              <div class="flex items-center text-gray-700 dark:text-gray-300">
                <svg
                  class="w-5 h-5 mr-2"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                  />
                </svg>
                <span>{formatDuration(video.data.duration)}</span>
              </div>
            )
          }
        </div>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      <!-- Main Content -->
      <div class="lg:col-span-3">
        <!-- Video Player -->
        <div class="mb-8">
          <div class="aspect-video bg-gray-900 rounded-2xl overflow-hidden">
            {
              video.data.embedUrl ? (
                <iframe
                  src={video.data.embedUrl}
                  title={video.data.title}
                  class="w-full h-full"
                  allowfullscreen
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center relative">
                  {video.data.thumbnail && (
                    <img
                      src={video.data.thumbnail}
                      class="absolute inset-0 w-full h-full object-cover opacity-30 blur-md"
                    />
                  )}
                  <div class="text-center text-white z-10 p-8">
                    <div class="text-6xl mb-4">🎬</div>
                    <p class="text-lg mb-4">{t("video.unavailable")}</p>
                    <a
                      href={video.data.sourceUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white font-medium rounded-lg transition-colors"
                    >
                      <svg
                        class="w-5 h-5 mr-2"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                        />
                      </svg>
                      {t("video.watchOriginal")}
                    </a>
                  </div>
                </div>
              )
            }
          </div>
        </div>

        <!-- Description -->
        <div
          class="bg-gradient-to-r from-indigo-50 to-purple-50 dark:from-indigo-900/30 dark:to-purple-900/30 rounded-xl p-6 mb-8"
        >
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">
            {t("video.description")}
          </h2>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
            {video.data.description}
          </p>
        </div>

        <!-- Topics -->
        <div class="mb-8">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">
            {t("video.relatedTopics")}
          </h2>
          <div class="flex flex-wrap gap-2">
            {
              video.data.topics.map((topic) => (
                <a
                  href={`/topics/${encodeURIComponent(topic)}`}
                  class="inline-block px-3 py-1 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 rounded-full text-sm hover:border-purple-500 dark:hover:border-purple-400 hover:text-purple-600 dark:hover:text-purple-400 transition-colors"
                >
                  #{getTopicTranslation(topic, currentLocale as any)}
                </a>
              ))
            }
          </div>
        </div>

        <!-- Action Buttons -->
        <div
          class="flex items-center justify-between py-4 border-y border-gray-200 dark:border-gray-700 mb-8"
        >
          <div class="flex items-center">
            <InteractionButtons
              contentId={`video-${video.slug}`}
              contentType="video"
              t={{
                like: t("interactions.like"),
                unlike: t("interactions.unlike"),
                bookmark: t("interactions.bookmark"),
                unbookmark: t("interactions.unbookmark"),
                loginToInteract: t("interactions.loginToInteract"),
              }}
              client:visible
            />
          </div>

          <a
            href={video.data.sourceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium rounded-lg transition-colors"
          >
            <svg
              class="w-4 h-4 mr-2"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
              ></path></svg
            >
            {t("video.originalLink")}
          </a>
        </div>

        <!-- Content -->
        <div class="prose prose-lg dark:prose-invert max-w-none">
          <Content />
        </div>

        <div class="mt-12">
          <Discussion
            contentId={`video-${video.slug}`}
            contentType="video"
            locale={currentLocale}
            client:load
          />
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <div class="sticky top-20 space-y-6">
          <!-- Info Card -->
          <div
            class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6"
          >
            <h3 class="font-semibold text-gray-900 dark:text-white mb-4">
              {t("video.videoInfo")}
            </h3>
            <div class="space-y-4 text-sm">
              <div class="flex flex-wrap gap-x-2">
                <span class="text-gray-600 dark:text-gray-400 shrink-0"
                  >{t("common.author")}:
                </span>
                <span class="text-gray-900 dark:text-white font-medium"
                  >{video.data.author}</span
                >
              </div>
              <div class="flex flex-wrap gap-x-2">
                <span class="text-gray-600 dark:text-gray-400 shrink-0"
                  >{t("common.publishDate")}:
                </span>
                <span class="text-gray-900 dark:text-white"
                  >{formatDateLoc(video.data.publishDate)}</span
                >
              </div>
              {
                video.data.duration && (
                  <div class="flex flex-wrap gap-x-2">
                    <span class="text-gray-600 dark:text-gray-400 shrink-0">
                      {t("common.duration")}:{" "}
                    </span>
                    <span class="text-gray-900 dark:text-white">
                      {formatDuration(video.data.duration)}
                    </span>
                  </div>
                )
              }
              <div class="flex flex-wrap gap-x-2">
                <span class="text-gray-600 dark:text-gray-400 shrink-0"
                  >{t("video.language")}:
                </span>
                <span class="text-gray-900 dark:text-white">
                  {
                    video.data.contentLanguage === "zh-CN"
                      ? "中文"
                      : video.data.contentLanguage === "en"
                        ? "English"
                        : video.data.contentLanguage || "Unknown"
                  }
                </span>
              </div>
            </div>

            <div
              class="border-t border-gray-200 dark:border-gray-600 pt-4 mt-6"
            >
              <button
                class="w-full px-4 py-2 bg-gradient-to-r from-purple-600 to-pink-600 text-white font-medium rounded-lg hover:from-purple-700 hover:to-pink-700 transition-all duration-200"
              >
                {t("video.addToPlaylist")}
              </button>
            </div>
          </div>

          <!-- Support -->
          <div
            class="bg-gradient-to-br from-yellow-50 to-orange-50 dark:from-yellow-900/20 dark:to-orange-900/20 rounded-xl p-6 shadow-sm border border-yellow-200 dark:border-yellow-800/30"
          >
            <h3
              class="font-semibold text-gray-900 dark:text-white mb-3 text-center"
            >
              {t("video.supportUs")}
            </h3>
            <p
              class="text-sm text-gray-600 dark:text-gray-400 mb-4 text-center"
            >
              {t("video.supportMessage")}
            </p>
            <a
              href="https://buymeacoffee.com/femres"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center px-8 py-4 bg-gradient-to-r from-yellow-400 to-orange-500 hover:from-yellow-500 hover:to-orange-600 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-200"
            >
              <svg class="w-6 h-6 mr-3" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M20.216 6.415l-.132-.666c-.119-.598-.388-1.163-.766-1.658a4.655 4.655 0 0 0-1.364-1.196c-.477-.298-1.009-.497-1.57-.588C15.999 2.193 15.618 2.124 15.232 2.124H8.768c-.386 0-.767.069-1.152.183-.561.091-1.093.29-1.57.588a4.655 4.655 0 0 0-1.364 1.196c-.378.495-.647 1.06-.766 1.658l-.132.666C3.657 6.79 3.563 7.168 3.563 7.548v8.9c0 .38.094.758.221 1.133l.132.666c.119.598.388 1.163.766 1.658.35.486.798.902 1.314 1.217.477.298 1.009.497 1.57.588.385.114.766.183 1.152.183h6.464c.386 0 .767-.069 1.152-.183.561-.091 1.093-.29 1.57-.588a4.655 4.655 0 0 0 1.364-1.217c.378-.495.647-1.06.766-1.658l.132-.666c.127-.375.221-.753.221-1.133v-8.9c0-.38-.094-.758-.221-1.133zM12 18.307c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.784 1.764-1.75 1.764zm1.75-6.711c0 .966-.784 1.75-1.75 1.75s-1.75-.784-1.75-1.75v-3.5c0-.966.784-1.75 1.75-1.75s1.75.784 1.75 1.75v3.5z"
                ></path>
              </svg>
              {t("contribute.support.button")}
            </a>
          </div>

          <FatefulDeckMiniPromo className="mt-8" />
        </div>

        <!-- Related Videos -->
        {
          relatedVideos.length > 0 && (
            <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6">
              <h3 class="font-semibold text-gray-900 dark:text-white mb-4">
                {t("video.relatedVideos")}
              </h3>
              <div class="space-y-4">
                {relatedVideos.map((rel) => {
                  let rSlug = rel.slug; // Root slug is clean
                  return (
                    <a
                      href={`/videos/${rSlug}`}
                      class="group flex gap-3 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg p-2 transition-colors"
                    >
                      <div class="flex-shrink-0 w-20 h-14 bg-gray-100 rounded-lg overflow-hidden">
                        {rel.data.thumbnail ? (
                          <img
                            src={rel.data.thumbnail}
                            class="w-full h-full object-cover"
                          />
                        ) : (
                          <span class="flex items-center justify-center h-full">
                            🎥
                          </span>
                        )}
                      </div>
                      <div class="flex-1 min-w-0">
                        <h4 class="font-medium text-gray-900 dark:text-white text-sm leading-tight mb-1 group-hover:text-purple-600 line-clamp-2">
                          {rel.data.title}
                        </h4>
                        <p class="text-xs text-gray-600 dark:text-gray-400">
                          {rel.data.author}
                        </p>
                      </div>
                    </a>
                  );
                })}
              </div>
            </div>
          )
        }
      </div>
    </div>
  </article>
  <!-- Newsletter/Share Section -->
  <section class="border-t border-gray-200 dark:border-gray-700 pt-12 mt-16">
    <div class="bg-gray-100 dark:bg-gray-800/50 rounded-2xl p-8 text-center">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">
        {t("newsletter.title")}
      </h2>
      <p class="text-gray-600 dark:text-gray-300 mb-6">
        {t("newsletter.description")}
      </p>
      <form
        id="newsletter-form"
        class="flex flex-col sm:flex-row gap-4 justify-center"
      >
        <input
          type="email"
          name="email"
          placeholder={t("auth.emailPlaceholder")}
          required
          class="px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-purple-500 focus:border-transparent outline-none min-w-[300px]"
        />
        <button
          type="submit"
          class="px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white font-bold rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        >
          {t("common.subscribe")}
        </button>
      </form>
      <p id="newsletter-message" class="mt-4 text-sm hidden"></p>
    </div>
  </section>

  <script>
    const form = document.getElementById(
      "newsletter-form",
    ) as HTMLFormElement | null;
    const messageEl = document.getElementById("newsletter-message");

    if (form) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const emailInput = form.querySelector(
          'input[name="email"]',
        ) as HTMLInputElement;
        const button = form.querySelector("button");
        if (!emailInput || !button) return;

        const email = emailInput.value;

        // Disable button
        button.disabled = true;
        const originalText = button.textContent;
        button.textContent = "...";

        try {
          const response = await fetch("/api/subscribe", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email, source: "video_detail" }),
          });

          const data = await response.json();

          if (data.success) {
            if (messageEl) {
              messageEl.textContent = "Subscribed successfully! / 订阅成功！";
              messageEl.className =
                "mt-4 text-sm text-green-600 dark:text-green-400 font-medium";
              messageEl.classList.remove("hidden");
            }
            form.reset();
          } else {
            if (messageEl) {
              messageEl.textContent =
                "Subscription failed. Please try again. / 订阅失败，请重试。";
              messageEl.className =
                "mt-4 text-sm text-red-600 dark:text-red-400 font-medium";
              messageEl.classList.remove("hidden");
            }
          }
        } catch (error) {
          if (messageEl) {
            messageEl.textContent = "An error occurred. / 发生错误。";
            messageEl.className =
              "mt-4 text-sm text-red-600 dark:text-red-400 font-medium";
            messageEl.classList.remove("hidden");
          }
        } finally {
          button.disabled = false;
          button.textContent = originalText;
        }
      });
    }
  </script>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
