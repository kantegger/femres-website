---

<section class={`tarot-showcase py-16 px-4 ${className}`}>
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-purple-600 to-pink-600 dark:from-purple-400 dark:to-pink-400 mb-4 font-serif">
        {t('promo.fatefuldeck.showcaseTitle') || "Discover Your Deck"}
      </h2>
      <p class="text-gray-600 dark:text-gray-300 max-w-2xl mx-auto text-lg leading-relaxed">
        {t('promo.fatefuldeck.showcaseDescription') || "Choose from multiple high-definition Tarot deck styles, each crafted with distinct spiritual resonance and artistic depth."}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 lg:gap-16">
      {decks.map((deck, index) => (
        <div 
          class="group relative deck-card flex flex-col items-center"
          data-deck-index={index}
          data-cards={JSON.stringify(deck.cards)}
          data-base-url={deck.baseUrl}
        >
          <div class={`relative ${deck.size} ${deck.rotate}`}>
            <div class="card-flip-container">
              <!-- Card Back (initially visible) -->
              <div class={`card-face card-back bg-gradient-to-br ${deck.color} rounded-xl shadow-2xl flex items-center justify-center p-2 border border-white/20`}>
                <img src={deck.back} alt={`${deck.name} Back`} class="w-full h-full object-cover rounded-lg opacity-80" />
              </div>
              
              <!-- Card Front (flips in on hover) -->
              <div class={`card-face card-front bg-gradient-to-br ${deck.color} rounded-xl shadow-2xl border border-white/20 overflow-hidden flex items-center justify-center`}>
                <img 
                  src={deck.baseUrl + deck.cards[0]} 
                  alt={deck.name} 
                  class="card-front-image w-full h-full object-cover"
                  data-deck-id={`deck-${index}`}
                />
              </div>
            </div>
          </div>
          
          <div class="mt-8 text-center opacity-0 group-hover:opacity-100 transition-opacity duration-500">
            <h3 class="text-xl font-bold text-gray-900 dark:text-white capitalize">{deck.name}</h3>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 text-center">
      <a 
        href="https://fatefuldeck.com?style=discovery" 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-flex items-center px-10 py-4 bg-purple-600 hover:bg-purple-700 text-white font-bold rounded-2xl shadow-2xl hover:shadow-purple-500/20 hover:-translate-y-1 transition-all group"
      >
        <span>{t('promo.fatefuldeck.showcaseCTA') || "Explore All Styles"}</span>
        <span class="ml-3 group-hover:translate-x-2 transition-transform duration-300">🔮</span>
      </a>
    </div>
  </div>
</section>

<style>
  .card-flip-container {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.7s;
  }
  
  .group:hover .card-flip-container {
    transform: rotateY(180deg);
  }
  
  .card-face {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
  
  .card-back {
    /* Back face is at 0deg initially (visible) */
    transform: rotateY(0deg);
  }
  
  .card-front {
    /* Front face is rotated 180deg initially (hidden) */
    transform: rotateY(180deg);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const deckCards = document.querySelectorAll('.deck-card');
    
    deckCards.forEach((deckCard) => {
      const cards = JSON.parse(deckCard.getAttribute('data-cards') || '[]');
      const baseUrl = deckCard.getAttribute('data-base-url') || '';
      const cardImage = deckCard.querySelector('.card-front-image') as HTMLImageElement;
      
      if (!cardImage || cards.length === 0) return;
      
      // Track failed images to avoid retrying them
      const failedImages = new Set<string>();
      
      // Function to get a random card that hasn't failed
      const getRandomCard = (): string => {
        const availableCards = cards.filter((card: string) => !failedImages.has(card));
        if (availableCards.length === 0) {
          // If all cards failed, reset and try again
          failedImages.clear();
          return cards[0];
        }
        const randomIndex = Math.floor(Math.random() * availableCards.length);
        return availableCards[randomIndex];
      };
      
      // Function to load image with validation
      const loadRandomCard = () => {
        const cardFilename = getRandomCard();
        const cardUrl = baseUrl + cardFilename;
        
        // Create a temporary image to test loading
        const tempImg = new Image();
        tempImg.onload = () => {
          // Image loaded successfully, update the display
          cardImage.src = cardUrl;
        };
        tempImg.onerror = () => {
          // Image failed to load, mark it and try another
          failedImages.add(cardFilename);
          console.warn(`Failed to load card: ${cardUrl}`);
          // Try loading another card if available
          if (failedImages.size < cards.length) {
            loadRandomCard();
          }
        };
        tempImg.src = cardUrl;
      };
      
      // Change card on mouseenter
      deckCard.addEventListener('mouseenter', () => {
        loadRandomCard();
      });
    });
  });
</script>
