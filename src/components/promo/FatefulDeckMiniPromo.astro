---
import { createT, getLocaleFromUrl } from "../../i18n/index";

const locale = getLocaleFromUrl(Astro.url);
const t = createT(locale);

interface Props {
    className?: string;
}

const { className = "" } = Astro.props;
---

<div
    class={`fatefuldeck-mini-promo group relative glass-card glass-hover bg-gradient-to-br from-purple-50/50 to-pink-50/50 dark:from-purple-900/10 dark:to-pink-900/10 rounded-xl p-6 shadow-sm border border-purple-200/50 dark:border-purple-800/20 hover:shadow-xl hover:-translate-y-1 hover:z-10 transition-all duration-300 ${className}`}
>
    <div class="flex justify-center mb-4">
        <div
            class="relative w-16 h-24 bg-gray-900 rounded-lg shadow-lg overflow-hidden border border-purple-500/30 group-hover:scale-105 group-hover:rotate-3 transition-all duration-500"
        >
            <img
                src="https://media.femres.org/images/fatefuldeck/Deck_2/back_deck_2.jpg"
                alt="Tarot Card Back"
                class="w-full h-full object-cover"
            />
            <div
                class="absolute inset-0 bg-gradient-to-tr from-purple-500/20 to-transparent"
            >
            </div>
        </div>
    </div>
    <h3
        class="font-semibold text-gray-900 dark:text-white mb-3 text-center group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors"
    >
        {t("promo.fatefuldeck.thanksSupport")}
    </h3>
    <p
        class="text-sm text-gray-600 dark:text-gray-400 mb-4 text-center group-hover:text-gray-700 dark:group-hover:text-gray-300 transition-colors"
    >
        {
            t("promo.fatefuldeck.thanksSupportMessage") ||
                "This project is supported by FatefulDeck.com - Your Daily Tarot Insight."
        }
    </p>
    <div class="flex justify-center">
        <a
        href="https://fatefuldeck.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-6 py-3 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white font-semibold rounded-lg shadow-md hover:shadow-xl hover:-translate-y-1 active:scale-[0.98] transition-all duration-300 text-center mx-auto"
    >
        <span
            class="inline-block mr-2 group-hover:rotate-12 group-hover:scale-125 transition-transform duration-300"
            >✨</span
        >
            {t("promo.fatefuldeck.checkFortune")}
        </a>
    </div>
</div>
