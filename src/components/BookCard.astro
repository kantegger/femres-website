---
import InteractionButtons from "./InteractionButtons";
import "../i18n/translations";
import {
  createT,
  getLocalizedPath,
  getLocaleFromUrl,
  type Locale,
} from "../i18n/index";
import { getTopicTranslation, findTopicByName } from "../i18n/topicsUtils";

export interface Props {
  title: string;
  originalTitle?: string;
  author: string;
  description: string;
  coverImage?: string;
  publishDate: Date;
  slug: string;
  topics: string[];
  isbn?: string;
  locale?: Locale;
}

const {
  title,
  originalTitle,
  author,
  description,
  coverImage,
  publishDate,
  slug,
  topics,
  isbn,
  locale,
} = Astro.props;

// 获取当前语言，如果没有传入locale则从URL获取
const currentLocale = locale || getLocaleFromUrl(Astro.url);
const t = createT(currentLocale);

// 根据语言选择显示内容
const displayTitle = title;
const displayDescription = description;

// 生成本地化链接
// 移除语言后缀以生成干净的URL路径
let cleanSlug = slug;
if (slug.endsWith("-en")) {
  cleanSlug = slug.slice(0, -3);
} else if (slug.endsWith("-ja")) {
  cleanSlug = slug.slice(0, -3);
} else if (slug.endsWith("-fr")) {
  cleanSlug = slug.slice(0, -3);
} else if (slug.endsWith("-tw")) {
  cleanSlug = slug.slice(0, -3);
}
const bookLink = getLocalizedPath(`books/${cleanSlug}`, currentLocale);

const formatYear = (date: Date) => {
  return date.getFullYear();
};
---

<article
  class="group relative bg-white dark:bg-gray-800 rounded-2xl shadow-sm hover:shadow-xl glass-card glass-hover transition-all duration-300 overflow-hidden min-h-[320px]"
>
  <div class="flex flex-col sm:flex-row h-full">
    <!-- Book Cover Section -->
    <div class="w-full sm:w-32 md:w-36 lg:w-40 flex-shrink-0 p-4 sm:pr-0">
      <div class="flex flex-col h-full">
        <!-- Book Cover -->
        <a
          href={bookLink}
          class="aspect-[2/3] bg-gradient-to-br from-purple-100 to-pink-100 dark:from-purple-900 dark:to-pink-900 relative overflow-hidden rounded-lg mb-3 block"
        >
          {
            coverImage ? (
              <img
                src={coverImage}
                alt={displayTitle}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center">
                <div class="text-center p-4">
                  <span class="text-4xl mb-2 block">📚</span>
                  <p class="text-xs text-gray-600 dark:text-gray-400 font-medium">
                    {t("common.loading")}
                  </p>
                </div>
              </div>
            )
          }
        </a>

        <!-- Cover Bottom Info - 封面下方信息 -->
        <div class="flex-1 flex flex-col justify-end min-h-0">
          <!-- Topics in Cover Area -->
          <div class="flex flex-wrap gap-1 justify-center">
            {
              topics.slice(0, 3).map((topic) => {
                const translatedTopic = getTopicTranslation(
                  topic,
                  currentLocale as any,
                );
                return (
                  <span class="inline-block px-2 py-1 text-xs bg-purple-50 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400 rounded text-center">
                    {translatedTopic}
                  </span>
                );
              })
            }
            {
              topics.length > 3 && (
                <span class="inline-block px-2 py-1 text-xs text-gray-500 dark:text-gray-500">
                  +{topics.length - 3}
                </span>
              )
            }
          </div>
        </div>
      </div>
    </div>

    <!-- Book Info -->
    <div class="flex-1 p-4 sm:p-5 flex flex-col">
      <a href={bookLink} class="flex-1 flex flex-col">
        <div class="mb-2">
          <h3
            class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors leading-tight line-clamp-3"
          >
            {displayTitle}
          </h3>
          {
            originalTitle && originalTitle !== displayTitle && (
              <p class="text-xs text-gray-500 dark:text-gray-400 italic mt-1 line-clamp-1">
                {originalTitle}
              </p>
            )
          }
        </div>

        <!-- Author -->
        <div class="mb-4">
          <p class="text-sm text-gray-600 dark:text-gray-400 flex items-center">
            <svg
              class="w-4 h-4 mr-2 text-gray-400 flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
              ></path>
            </svg>
            <span class="font-medium">{author}</span>
            <span class="text-gray-500 dark:text-gray-500 ml-2"
              >({formatYear(publishDate)})</span
            >
          </p>
        </div>

        <!-- Description -->
        <div class="flex-1 mb-4">
          <p
            class="text-gray-700 dark:text-gray-300 text-sm leading-relaxed line-clamp-5"
          >
            {displayDescription}
          </p>
        </div>

        <!-- Read More Link -->
        <div class="text-right mt-auto">
          <span
            class="text-purple-600 dark:text-purple-400 text-sm font-medium group-hover:underline"
          >
            {t("common.readMore")} →
          </span>
        </div>
      </a>

      <div
        class="flex justify-end pt-3 border-t border-gray-100 dark:border-gray-700"
      >
        <InteractionButtons
          contentId={`book-${slug}`}
          contentType="book"
          t={{
            like: t("interactions.like"),
            unlike: t("interactions.unlike"),
            bookmark: t("interactions.bookmark"),
            unbookmark: t("interactions.unbookmark"),
            loginToInteract: t("interactions.loginToInteract"),
          }}
          client:visible
        />
      </div>
    </div>
  </div>
</article>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-4 {
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-5 {
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
