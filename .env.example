# Database (Supabase Postgres)
# Get connection string from Supabase Dashboard > Settings > Database
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Cloudflare R2 Storage (for media files)
# Get API tokens from Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=femres-media

# Old Database (Neon) - Only needed for data migration
# Add this temporarily when running migrate-to-supabase.ts
# NEON_DATABASE_URL=postgresql://neondb_owner:[PASSWORD]@ep-[...].neon.tech/neondb?sslmode=require

# Authentication
JWT_SECRET=your-secret-key-here

# AdSense Configuration (Optional - for monetization)
# Replace with your actual AdSense IDs
PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXX

# Ad Unit IDs
PUBLIC_ADSENSE_AFTER_HEADER=YOUR_AD_SLOT_ID
PUBLIC_ADSENSE_AFTER_CONTENT=YOUR_AD_SLOT_ID
PUBLIC_ADSENSE_BEFORE_RELATED=YOUR_AD_SLOT_ID
PUBLIC_ADSENSE_IN_ARTICLE=YOUR_AD_SLOT_ID
PUBLIC_ADSENSE_MULTIPLEX=YOUR_AD_SLOT_ID
PUBLIC_ADSENSE_SIDEBAR_TOP=YOUR_AD_SLOT_ID
PUBLIC_ADSENSE_SIDEBAR_BOTTOM=YOUR_AD_SLOT_ID